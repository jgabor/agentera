  "main": "./plugins/agentera.js",
  "exports": {
    ".": "./plugins/agentera.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.14.33"
  },
  "agentera": {
    "packageShape": "npm-loadable-plugin",
