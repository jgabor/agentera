#!/usr/bin/env bash
# Ecosystem alignment linter — runs on commits touching skills or the spec.
# Enable with: git config core.hooksPath .githooks

# Check if any staged files match skills/*/SKILL.md or references/ecosystem-spec.md
RELEVANT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(skills/.*/SKILL\.md|references/ecosystem-spec\.md)$')

if [ -z "$RELEVANT_FILES" ]; then
    exit 0
fi

echo "==> Running ecosystem linter (staged skill/spec changes detected)..."
python3 scripts/validate_ecosystem.py
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "Commit blocked: ecosystem linter found errors."
    echo "Fix the issues above and try again."
fi

exit $EXIT_CODE
