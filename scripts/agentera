def _active_app_model() -> dict[str, Path | str]:
    source_root = Path(__file__).resolve().parent.parent
    if _is_installed_managed_app(source_root):
        if os.environ.get("AGENTERA_HOME") or os.environ.get("AGENTERA_DEFAULT_INSTALL_ROOT"):
            selected = resolve_active_app_model(home=Path.home().expanduser().resolve())
            if _model_path(selected, "appHome") != source_root.parent:
                return selected
            selected["runtimeRoot"] = source_root
            return selected
        app_home = source_root.parent
        return {
            "appHome": app_home,
            "appHomeSource": "installed app",
            "managedAppRoot": source_root,
            "activeBundleRoot": source_root,
            "authoritativeRoot": source_root,
            "skillRoot": source_root / "skills" / "agentera",
            "runtimeRoot": source_root,
        }
    if not os.environ.get("AGENTERA_HOME") and not os.environ.get("AGENTERA_DEFAULT_INSTALL_ROOT") and _is_local_agentera_checkout(source_root):
        return {
            "appHome": source_root,
            "appHomeSource": "local checkout",
            "managedAppRoot": source_root,
            "activeBundleRoot": source_root,
            "authoritativeRoot": source_root,
            "skillRoot": source_root / "skills" / "agentera",
            "runtimeRoot": source_root,
        }
    return resolve_active_app_model(home=Path.home().expanduser().resolve())


def _model_path(model: dict[str, Path | str], key: str) -> Path:
    value = model[key]
    return value if isinstance(value, Path) else Path(str(value))


def _discover_schemas_dir(model: dict[str, Path | str] | None = None) -> Path:
    model = model or _active_app_model()
    return _model_path(model, "skillRoot") / "schemas" / "artifacts"


def _app_model_payload(model: dict[str, Path | str] | None = None) -> dict[str, str]:
    model = model or _active_app_model()
    return {key: str(value) for key, value in model.items()}


def _surface_missing_message(surface: str, path: Path, model: dict[str, Path | str] | None = None) -> str:
    payload = _app_model_payload(model)
    return (
        f"{surface} is missing. Agentera cannot find it at {path}. "
        f"Agentera directory: {payload['appHome']}. "
        f"App files directory: {payload['managedAppRoot']}. "
        "Run `agentera doctor` to preview the repair; run "
        "`agentera doctor --format json` for structured details. "
        f"Technical details: appHome={payload['appHome']} managedAppRoot={payload['managedAppRoot']} "
        f"skillRoot={payload['skillRoot']} runtimeRoot={payload['runtimeRoot']}."
    )


def _load_self_audit_helper(model: dict[str, Path | str] | None = None) -> Any:
    model = model or _active_app_model()
    helper = _model_path(model, "activeBundleRoot") / "scripts" / "self_audit.py"
    if not helper.is_file():
        raise RuntimeError(_surface_missing_message("lint helper", helper, model))
    spec = importlib.util.spec_from_file_location("agentera_self_audit", helper)
    if spec is None or spec.loader is None:
        raise RuntimeError(_surface_missing_message("lint helper", helper, model))
    module = importlib.util.module_from_spec(spec)
    sys.modules["agentera_self_audit"] = module
    spec.loader.exec_module(module)
    return module


def _load_compaction_helper(model: dict[str, Path | str] | None = None) -> Any:
    model = model or _active_app_model()
    candidates = [
        _model_path(model, "activeBundleRoot") / "hooks" / "compaction.py",
        Path(__file__).resolve().parent.parent / "hooks" / "compaction.py",
    ]
    last_helper = candidates[0]
    for helper in candidates:
        last_helper = helper
        if not helper.is_file():
            continue
        spec = importlib.util.spec_from_file_location("agentera_compaction_cli", helper)
        if spec is None or spec.loader is None:
            continue
        module = importlib.util.module_from_spec(spec)
        sys.modules["agentera_compaction_cli"] = module
        spec.loader.exec_module(module)
        if hasattr(module, "run_compaction"):
            return module
    raise RuntimeError(_surface_missing_message("compaction helper", last_helper, model))


def _load_schemas(schemas_dir: Path) -> dict[str, dict[str, Any]]:
    if not schemas_dir.is_dir():
        return {}
    registry = _load_registry_for_schemas(schemas_dir)
    schemas: dict[str, dict[str, Any]] = {}
    for schema_file in sorted(schemas_dir.glob("*.yaml")):
        try:
            with open(schema_file) as f:
                schema = yaml.safe_load(f)
        except Exception:
            continue
        if not isinstance(schema, dict):
            continue
        meta = schema.get("meta", {})
        name = meta.get("name", "")
        artifact_path = meta.get("path", "")
        if not name:
            continue
        fields = _discover_fields(schema)
        schemas[name] = {
            "path": artifact_path,
            "record": registry.get(name),
            "schema": schema,
            "fields": fields,
        }
    return schemas


def _missing_schema_error(schema_name: str) -> str:
    model = _active_app_model()
    schemas_dir = _discover_schemas_dir(model)
    return _surface_missing_message(f"{schema_name} schema", schemas_dir / f"{schema_name}.yaml", model)


def _load_registry_for_schemas(schemas_dir: Path) -> dict[str, ArtifactRecord]:
    root = schemas_dir.parents[3] if len(schemas_dir.parents) > 3 else Path.cwd()
    model_path = root / "references" / "artifacts" / "artifact-registry-interface-model.yaml"
    if not model_path.is_file():
        model_path = Path(__file__).resolve().parent.parent / "references" / "artifacts" / "artifact-registry-interface-model.yaml"
    try:
        return load_artifact_registry(schemas_dir, model_path)
    except Exception:
        return {}


def _discover_fields(schema: dict) -> dict[str, dict]:
    skip = {
        "meta", "GROUP_PREFIXES", "BUDGET", "COMPACTION", "VALIDATION",
        "ARCHIVE",
    }
    fields: dict[str, dict] = {}
    for group_key, group_val in schema.items():
        if group_key in skip or not isinstance(group_val, dict):
            continue
        for _num, entry in group_val.items():
            if isinstance(entry, dict) and "field" in entry:
                fields[entry["field"]] = entry
    return fields


def _active_objective_name() -> str | None:
    root = Path.cwd() / ".agentera" / "optimera"
    if not root.is_dir():
        return None
    candidates = [p for p in root.iterdir() if p.is_dir()]
    if not candidates:
        return None
    active: list[Path] = []
    for candidate in candidates:
        objective = candidate / "objective.yaml"
        if not objective.exists():
            continue
        try:
            data = yaml.safe_load(objective.read_text(encoding="utf-8"))
        except Exception:
            continue
        status = ""
        if isinstance(data, dict):
            header = data.get("header")
            if isinstance(header, dict):
                status = str(header.get("status", ""))
            if not status:
                status = str(data.get("status", ""))
        if status.lower() == "active":
            active.append(candidate)
    pool = active or candidates
    pool.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return pool[0].name


def _resolve_artifact_path(
    artifact_rel_path: str,
    schema_name: str | None = None,
    record: ArtifactRecord | None = None,
) -> Path:
    if record is not None:
        return resolve_artifact_path(record, Path.cwd(), _active_objective_name())
    if "<name>" in artifact_rel_path:
        objective_name = _active_objective_name()
        if objective_name:
            artifact_rel_path = artifact_rel_path.replace("<name>", objective_name)
    p = Path(artifact_rel_path)
    if p.is_absolute():
        return p
    return Path.cwd() / p


def _artifact_path(info: dict[str, Any], schema_name: str) -> Path:
    record = info.get("record")
    return _resolve_artifact_path(
        str(info.get("path", "")),
        schema_name,
        record if isinstance(record, ArtifactRecord) else None,
    )


def _has_control_chars(value: str) -> bool:
    return CONTROL_CHAR_RE.search(value) is not None


def _validate_agent_string(value: str, label: str) -> None:
    if _has_control_chars(value):
        raise ValueError(f"{label} contains control characters")


def _validate_identifier(value: str, label: str) -> None:
    _validate_agent_string(value, label)
    if not IDENTIFIER_RE.fullmatch(value):
        raise ValueError(f"unsupported {label} {value!r}; use letters, digits, '_' or '-'")


def _validate_path_value(value: str, label: str) -> None:
    _validate_agent_string(value, label)
    if ENCODED_TRAVERSAL_RE.search(value):
        raise ValueError(f"unsafe {label}: encoded traversal or path separator is not supported")
    if URI_SCHEME_RE.match(value) and not re.match(r"^[A-Za-z]:[\\/]", value):
        raise ValueError(f"unsupported {label}: URI-style paths are not supported")
    if any(part == ".." for part in Path(value).parts):
        raise ValueError(f"unsafe {label}: traversal segments are not supported")


def _agent_path(value: str) -> Path:
    try:
        _validate_path_value(value, "path")
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    return Path(value)


def _agent_command(value: str) -> str:
    try:
        _validate_identifier(value, "command name")
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    return value


def _agent_version(value: str) -> str:
    try:
        _validate_agent_string(value, "expected version")
    except ValueError as exc:
        raise argparse.ArgumentTypeError(str(exc)) from exc
    if not VERSION_RE.fullmatch(value):
        raise argparse.ArgumentTypeError(
            f"unsupported expected version {value!r}; use version characters only",
        )
    return value


def _validate_filter_values(args: argparse.Namespace, names: list[str]) -> None:
    for name in names:
        value = getattr(args, name, None)
        values = value if isinstance(value, list) else [value]
        for item in values:
            if item is not None:
                _validate_agent_string(str(item), name.replace("_", " "))


def _load_artifact(path: Path) -> Any:
    if not path.exists():
        return None
    try:
        with open(path) as f:
            return yaml.safe_load(f)
    except Exception:
        return None


def _registry_artifact_path(artifact_id: str, schemas_dir: Path) -> Path:
    record = _load_registry_for_schemas(schemas_dir).get(artifact_id)
    if record is None:
        raise RuntimeError(f"artifact registry does not define {artifact_id!r}")
    return _resolve_artifact_path("", record=record)


V1_ARTIFACT_PAIRS = [
    (".agentera/PROGRESS.md", ".agentera/progress.yaml"),
    (".agentera/PLAN.md", ".agentera/plan.yaml"),
    (".agentera/DECISIONS.md", ".agentera/decisions.yaml"),
    (".agentera/HEALTH.md", ".agentera/health.yaml"),
    (".agentera/SESSION.md", ".agentera/session.yaml"),
    (".agentera/DOCS.md", ".agentera/docs.yaml"),
    ("VISION.md", ".agentera/vision.yaml"),
]


def _detect_v1_artifacts() -> list[str]:
    root = Path.cwd()
    found = []
    for markdown_rel, yaml_rel in V1_ARTIFACT_PAIRS:
        if (root / markdown_rel).exists() and not (root / yaml_rel).exists():
            found.append(markdown_rel)
    return found


def _is_local_agentera_checkout(root: Path) -> bool:
    return all(
        (root / rel).exists()
        for rel in ("scripts/agentera", "skills/agentera/SKILL.md", "registry.json")
    )


def _is_installed_managed_app(root: Path) -> bool:
    return root.name == "app" and (root / ".agentera-bundle.json").is_file() and _is_local_agentera_checkout(root)


def _v1_migration_summary(v1_artifacts: list[str]) -> dict[str, Any]:
    dry_run = 'uvx --from git+https://github.com/jgabor/agentera agentera upgrade --project "$PWD" --dry-run'
    apply = 'uvx --from git+https://github.com/jgabor/agentera agentera upgrade --project "$PWD" --yes'
    summary: dict[str, Any] = {
        "detected": bool(v1_artifacts),
        "affected_files": v1_artifacts,
        "dry_run_command": dry_run if v1_artifacts else None,
        "apply_command": apply if v1_artifacts else None,
        "requires_confirmation": bool(v1_artifacts),
    }
    if v1_artifacts and _is_local_agentera_checkout(Path.cwd()):
        summary["local_dry_run_command"] = 'uv run scripts/agentera upgrade --project "$PWD" --dry-run'
        summary["local_apply_command"] = 'uv run scripts/agentera upgrade --project "$PWD" --yes'
    return summary


def _frontmatter_version(path: Path) -> str | None:
    if not path.is_file():
        return None
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except OSError:
        return None
    if not lines or lines[0].strip() != "---":
        return None
    for line in lines[1:]:
        stripped = line.strip()
        if stripped == "---":
            return None
        if stripped.startswith("version:"):
            version = stripped.split(":", 1)[1].strip().strip('"\'')
            return version if version else None
    return None


def _version_key(version: str | None) -> tuple[int, ...]:
    if not version:
        return ()
    parts = []
    for item in re.split(r"[.+_-]", version):
        if item.isdigit():
            parts.append(int(item))
        else:
            break
    return tuple(parts)


def _visible_skill_version(home: Path) -> tuple[str | None, str | None]:
    candidates = []
    if os.environ.get("AGENTERA_VISIBLE_SKILL_ROOT"):
        candidates.append(Path(os.environ["AGENTERA_VISIBLE_SKILL_ROOT"]).expanduser())
    candidates.extend([
        home / ".agents" / "skills" / "agentera",
        home / ".config" / "opencode" / "skills" / "agentera",
    ])
    versions: list[tuple[tuple[int, ...], str, Path]] = []
    for root in candidates:
        version = _frontmatter_version(root / "SKILL.md")
        if version:
            versions.append((_version_key(version), version, root))
    if not versions:
        return None, None
    versions.sort(reverse=True)
    _key, version, root = versions[0]
    return version, str(root)


def _hej_expected_version(args: argparse.Namespace, source_root: Path, home: Path) -> tuple[str | None, str]:
    explicit = getattr(args, "expected_version", None)
    if explicit:
        return explicit, "--expected-version"
    env_version = os.environ.get("AGENTERA_EXPECTED_VERSION")
    if env_version:
        return env_version, "AGENTERA_EXPECTED_VERSION"
    source_version = load_suite_version(source_root)
    visible_version, visible_source = _visible_skill_version(home)
    if visible_version and _version_key(visible_version) >= _version_key(source_version):
        return visible_version, visible_source or "visible skill"
    return source_version, "source registry"


def _hej_bundle_status(args: argparse.Namespace) -> dict[str, Any]:
    home = getattr(args, "home", Path.home()).expanduser().resolve()
    source_root = resolve_source_root()
    install_root, root_source = resolve_doctor_install_root(
        getattr(args, "install_root", None),
        home=home,
        source_root=source_root,
    )
    expected, expected_source = _hej_expected_version(args, source_root, home)
    status = build_doctor_status(
        install_root,
        root_source=root_source,
        source_root=source_root,
        home=home,
        project=Path.cwd().resolve(),
        expected_version=expected,
        expected_commands=("hej",),
        probe_cli=False,
    )
    status["expectedVersionSource"] = expected_source
    return status


def _extract_entries(data: Any) -> list[dict]:
    if data is None:
        return []
    if isinstance(data, list):
        return [e for e in data if isinstance(e, dict)]
    if isinstance(data, dict):
        for key, val in data.items():
            if key == "archive":
                continue
            if isinstance(val, list) and val and isinstance(val[0], dict):
                return val
        return [data]
    return []


_DECISION_ARCHIVE_RE = re.compile(r"Decision\s+(?P<number>\d+)(?:\s+\((?P<date>\d{4}-\d{2}-\d{2})\))?:\s*(?P<summary>.*)")


def _decision_archive_entry(entry: Any) -> dict[str, Any]:
    if isinstance(entry, dict):
        archive_entry = dict(entry)
    else:
        archive_entry = {"summary": str(entry)}
    archive_entry["compacted"] = True
    summary = str(archive_entry.get("summary") or "")
    match = _DECISION_ARCHIVE_RE.search(summary)
    if match:
        archive_entry.setdefault("number", int(match.group("number")))
        if match.group("date"):
            archive_entry.setdefault("date", match.group("date"))
    return archive_entry


def _extract_decision_entries(data: Any) -> list[dict[str, Any]]:
    if not isinstance(data, dict):
        return _extract_entries(data)
    decisions = data.get("decisions") or []
    archive = data.get("archive") or []
    entries = [entry for entry in decisions if isinstance(entry, dict)] if isinstance(decisions, list) else []
    if isinstance(archive, list):
        entries.extend(_decision_archive_entry(entry) for entry in archive)
    return entries


def _as_list(value: Any) -> list:
    return value if isinstance(value, list) else []


def _truncate(value: Any, limit: int = 110) -> str:
    text = _format_scalar(value).replace("\n", " ")
    return text[: limit - 3] + "..." if len(text) > limit else text


def _first_present(entry: dict, names: list[str], default: Any = "") -> Any:
    for name in names:
        value = entry.get(name)
        if value is not None and value != "":
            return value
    return default


def _status_counts(entries: list[dict]) -> dict[str, int]:
    counts: dict[str, int] = {}
    for entry in entries:
        status = str(entry.get("status", "unknown") or "unknown")
        counts[status] = counts.get(status, 0) + 1
    return counts


def _print_status_counts(prefix: str, counts: dict[str, int]) -> None:
    if counts:
        body = ", ".join(f"{name}={count}" for name, count in sorted(counts.items()))
        print(f"{prefix}: {body}")


def _string_field_names(fields: dict) -> list[str]:
    return [n for n, d in fields.items() if d.get("type") == "string"]


def _filter_by_topic(entries: list[dict], topic: str, fields: dict) -> list[dict]:
    t = topic.lower()
    fnames = _string_field_names(fields)
    return [
        e for e in entries
        if any(t in str(e.get(fn, "")).lower() for fn in fnames)
    ]


def _filter_decisions_by_topic(entries: list[dict], topic: str, fields: dict) -> list[dict]:
    t = topic.lower()
    fnames = [*_string_field_names(fields), "summary", "outcome"]
    return [
        entry for entry in entries
        if any(t in str(entry.get(field, "")).lower() for field in fnames)
    ]


def _filter_by_field_value(
    entries: list[dict],
    field_name: str,
    value: str,
    *,
    substring: bool = False,
) -> list[dict]:
    vl = value.lower()
    result = []
    for e in entries:
        v = e.get(field_name)
        if v is None:
            continue
        if isinstance(v, str):
            if (substring and vl in v.lower()) or (not substring and v.lower() == vl):
                result.append(e)
        elif isinstance(v, list):
            strs = [str(x).lower() for x in v]
            if vl in strs or (substring and any(vl in s for s in strs)):
                result.append(e)
        elif isinstance(v, dict):
            if vl in v or (substring and any(vl in str(k).lower() for k in v)):
                result.append(e)
    return result


_PRIORITY_FIELDS = [
    "number", "name", "title", "date", "timestamp", "status",
    "phase", "choice", "grade", "type", "label", "trajectory",
    "confidence",
]


def _display_fields(fields: dict, limit: int = 6) -> list[str]:
    ordered = [p for p in _PRIORITY_FIELDS if p in fields]
    for fn in fields:
        if fn not in ordered:
            ordered.append(fn)
    return ordered[:limit]


def _cycle_sort_key(entry: dict) -> tuple[int, int | str]:
    number = entry.get("number")
    if isinstance(number, int):
        return (1, number)
    if isinstance(number, str) and number.isdigit():
        return (1, int(number))
    timestamp = entry.get("timestamp")
    if isinstance(timestamp, str):
        return (0, timestamp)
    return (0, "")


def _recent_cycles(entries: list[dict], limit: int) -> list[dict]:
    return sorted(entries, key=_cycle_sort_key, reverse=True)[:limit]


def _format_scalar(val: Any) -> str:
    if isinstance(val, (list, dict)):
        s = str(val)
        return s[:80] + "..." if len(s) > 80 else s
    return str(val)


def _format_entry(entry: dict, fields: list[str]) -> str:
    parts = []
    for field in fields:
        value = entry.get(field)
        if value is not None and value != "" and not isinstance(value, (list, dict)):
            parts.append(f"{field}={_truncate(value)}")
    return " | ".join(parts)


def _emit_structured(value: Any, output_format: str) -> None:
    if output_format == "json":
        print(json.dumps(value, ensure_ascii=False, indent=2, default=_json_default))
    elif output_format == "yaml":
        print(yaml.safe_dump(value, sort_keys=False), end="")


def _json_default(value: Any) -> str:
    if isinstance(value, date):
        return value.isoformat()
    raise TypeError(f"Object of type {value.__class__.__name__} is not JSON serializable")


def _output_format(args: argparse.Namespace) -> str:
    return getattr(args, "format", "text")


