def _app_status_attention(bundle: dict[str, Any]) -> str:
    if bundle["status"] == "outdated":
        return f"normal: app update needed; preview `{bundle['dryRunCommand']}`; app_home={bundle['appHome']}"
    if bundle.get("dryRunCommand"):
        label = str(bundle["status"]).replace("_", " ")
        return f"degraded: app {label}; preview `{bundle['dryRunCommand']}`; app_home={bundle['appHome']}"
    return (
        f"critical: app {str(bundle['status']).replace('_', ' ')}; fix AGENTERA_HOME or choose a managed app home; "
        f"app_home={bundle['appHome']}"
    )

