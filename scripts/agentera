#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""agentera CLI: query project state, upgrade installs, and print priming guidance.

Commands:
  agentera prime             Print static agent-priming guidance
  agentera hej               Composite orientation briefing
  agentera plan              Active plan summary
  agentera progress          Recent cycle summary
  agentera health            Latest audit data
  agentera todo              TODO summary
  agentera decisions         Decision log
  agentera docs              Documentation contract summary
  agentera objective         Active optimera objective summary
  agentera experiments       Active optimera experiments summary
  agentera gate              Run check-only repository gates
  agentera verify            Run bounded smoke or eval verification gates
  agentera compact           Check or fix artifact compaction budgets
  agentera describe          Runtime CLI/schema introspection
  agentera lint              Pre-write artifact prose self-audit
  agentera validate          Validate capabilities or artifacts
  agentera query <artifact>  Advanced custom artifact query
  agentera upgrade           Plan or apply a v1-to-v2 upgrade

Advanced query patterns:
  query --list-artifacts          List all discovered artifact schemas
  query <artifact-name>           Generic query against custom discovered schemas

Schema discovery is automatic. The CLI resolves artifact schemas from the
active app model reported by `agentera describe` and `agentera doctor`, then
supports queries against any artifact whose schema exists.
"""

from __future__ import annotations

