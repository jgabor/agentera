def _app_status_attention(bundle: dict[str, Any]) -> str:
    if bundle["status"] == "update_needed":
        return f"normal: app update needed; preview `{bundle['dryRunCommand']}`; app_home={bundle['appHome']}"
    if bundle.get("dryRunCommand"):
        return f"degraded: app {bundle['status']}; preview `{bundle['dryRunCommand']}`; app_home={bundle['appHome']}"
    return (
        f"critical: app {bundle['status']}; fix AGENTERA_HOME or choose a managed app home; "
        f"app_home={bundle['appHome']}"
    )

