def _available_structured_fields(command: str) -> list[str]:
    return HEJ_STRUCTURED_FIELDS if command == "hej" else ROUTINE_STRUCTURED_FIELDS


def _requested_fields(args: argparse.Namespace) -> list[str]:
    raw = getattr(args, "fields", None)
    if not raw:
        return []
    _validate_agent_string(str(raw), "fields")
    fields: list[str] = []
    for part in str(raw).split(","):
        field = part.strip()
        if field and field not in fields:
            _validate_identifier(field, "field")
            fields.append(field)
    return fields


def _select_structured_fields(
    command: str,
    value: dict[str, Any],
    args: argparse.Namespace,
) -> dict[str, Any] | None:
    requested = _requested_fields(args)
    if not requested:
        return value
    available = _available_structured_fields(command)
    unsupported = [field for field in requested if field not in available]
    if unsupported:
        print(
            f"Error: unsupported field '{unsupported[0]}' for {command}. "
            f"Available fields: {', '.join(available)}",
            file=sys.stderr,
        )
        return None
    selected: dict[str, Any] = {}
    for field in [*REQUIRED_SPARSE_CONTEXT_FIELDS, *requested]:
        if field in value and field not in selected:
            selected[field] = value[field]
    return selected


def _emit_state_structured(command: str, value: dict[str, Any], args: argparse.Namespace) -> int:
    selected = _select_structured_fields(command, value, args)
    if selected is None:
        return 1
    _emit_structured(selected, _output_format(args))
    return 0


def _source_metadata(command: str, path: Path | None, *, schema: str | None = None) -> dict[str, Any]:
    return {
        "artifact": schema or command,
        "path": str(path) if path is not None else None,
        "exists": bool(path and path.exists()),
        "kind": "markdown" if path and path.suffix.lower() == ".md" else "yaml",
    }


def _structured_state(
    command: str,
    entries: list[dict],
    source: dict[str, Any],
    *,
    filters: dict[str, Any] | None = None,
    summary: dict[str, Any] | None = None,
    source_contract: dict[str, Any] | None = None,
) -> dict[str, Any]:
    payload = {
        "command": command,
        "status": "ok" if entries or source.get("exists") else "empty",
        "entries": entries,
        "counts": {
            "entries": len(entries),
            "status": _status_counts(entries),
        },
        "source": source,
        "filters": {k: v for k, v in (filters or {}).items() if v is not None},
        "summary": summary or {},
    }
    if source_contract is not None:
        payload["source_contract"] = source_contract
    return payload


DECISION_CONTEXT_FIELDS = [
    "number",
    "date",
    "question",
    "context",
    "alternatives",
    "choice",
    "reasoning",
    "confidence",
    "feeds_into",
]


def _decision_field_missing(entry: dict[str, Any], field: str) -> bool:
    value = entry.get(field)
    return value is None or value == "" or value == [] or value == {}


def _decision_downstream_references(entry: dict[str, Any]) -> list[dict[str, str]] | None:
    value = entry.get("feeds_into")
    if value is None or value == "":
        return None
    if isinstance(value, list):
        refs = [str(item).strip() for item in value if str(item).strip()]
    else:
        refs = [part.strip() for part in str(value).split(",") if part.strip()]
    if not refs:
        return None
    return [{"source_field": "feeds_into", "reference": ref} for ref in refs]


def _decision_context_entry(entry: dict[str, Any]) -> dict[str, Any]:
    enriched = dict(entry)
    if enriched.get("outcome") in (None, "") and enriched.get("choice") not in (None, ""):
        enriched["outcome"] = enriched["choice"]

    compacted = bool(enriched.get("compacted")) or (
        "summary" in enriched
        and any(_decision_field_missing(enriched, field) for field in ("question", "reasoning", "confidence"))
    )
    missing_fields = [field for field in DECISION_CONTEXT_FIELDS if _decision_field_missing(enriched, field)]
    if _decision_field_missing(enriched, "choice") and _decision_field_missing(enriched, "outcome"):
        missing_fields.append("outcome")

    downstream_references = _decision_downstream_references(enriched)
    caveats: list[str] = []
    if compacted:
        caveats.append("Decision entry is compacted; full decision context is not available in this CLI result.")
    if missing_fields:
        caveats.append("Decision entry is missing one or more full-detail context fields.")
    if downstream_references is None:
        caveats.append("No explicit downstream consequence references were present; none were inferred.")

    enriched["downstream_consequence_references"] = downstream_references
    enriched["context_complete"] = not compacted and not missing_fields and downstream_references is not None
    enriched["missing_fields"] = missing_fields
    enriched["compacted"] = compacted
    enriched["caveats"] = caveats
    return enriched


def _decision_source_contract(source: dict[str, Any], entries: list[dict[str, Any]], filters: dict[str, Any]) -> dict[str, Any]:
    compacted_entries = sum(1 for entry in entries if entry.get("compacted"))
    entries_with_missing_fields = sum(1 for entry in entries if entry.get("missing_fields"))
    entries_without_downstream_references = sum(
        1 for entry in entries if entry.get("downstream_consequence_references") is None
    )
    complete_for_returned = bool(source.get("exists")) and all(
        entry.get("context_complete") is True for entry in entries
    )
    caveats = [
        "Downstream consequence references are derived only from explicit structured feeds_into values; no references are inferred.",
        "Compacted archive decisions are not expanded by this command and are not complete full-detail decision context.",
    ]
    if entries_with_missing_fields:
        caveats.append("One or more returned decisions are missing full-detail context fields.")
    if entries_without_downstream_references:
        caveats.append("One or more returned decisions lack explicit downstream consequence references.")
    return {
        "artifact": "DECISIONS.md",
        "path": source.get("path"),
        "complete_for_returned_decisions": complete_for_returned,
        "complete_for_decision_context": complete_for_returned,
        "completeness": {
            "returned_decisions": len(entries),
            "context_complete": complete_for_returned,
            "compacted_entries": compacted_entries,
            "entries_with_missing_fields": entries_with_missing_fields,
            "entries_without_downstream_references": entries_without_downstream_references,
        },
        "included_fields": [
            *DECISION_CONTEXT_FIELDS,
            "outcome",
            "downstream_consequence_references",
            "context_complete",
            "missing_fields",
            "compacted",
            "caveats",
        ],
        "raw_artifact_reads_required": False,
        "raw_artifact_read_policy": (
            "Use `agentera decisions --format json` for normal deliberation context. "
            "Do not read `.agentera/decisions.yaml` unless investigating artifact corruption or CLI defects; "
            "historical compacted gaps are exposed through missing_fields and caveats."
        ),
        "caveats": caveats,
        "fallback_behavior": {
            "normal": "Use this command's entries and source_contract; no raw decision artifact read is required for returned full-detail or compacted decision entries.",
            "filtered_result": "The same per-decision guarantees apply after filters; an empty filtered result means no matching returned decisions.",
            "missing_or_incomplete": "If a required field is missing, treat only the present structured fields as authoritative and do not infer absent context.",
            "compacted_history": "Compacted archive decisions are included with explicit missing_fields and caveats; treat absent historical context as unavailable during normal deliberation.",
        },
        "filters": {key: value for key, value in filters.items() if value is not None},
    }


def _plan_artifact_summary(data: dict[str, Any], header: dict[str, Any]) -> dict[str, Any]:
    summary = {
        "header": header,
        "title": _first_present(header, ["title"], data.get("title", "")),
        "status": _first_present(header, ["status"], data.get("status", "")),
        "created": _first_present(header, ["created"], data.get("created", "")),
        "what": data.get("what"),
        "why": data.get("why"),
        "constraints": data.get("constraints"),
        "scope": data.get("scope"),
        "design": data.get("design"),
        "overall_acceptance": data.get("overall_acceptance"),
        "surprises": data.get("surprises"),
        "previous_plan_archived": data.get("previous_plan_archived"),
    }
    return {key: value for key, value in summary.items() if value not in (None, "")}


def _plan_source_contract(source: dict[str, Any], summary: dict[str, Any]) -> dict[str, Any]:
    complete = bool(source.get("exists"))
    return {
        "artifact": "PLAN.md",
        "complete_for_plan_artifact": complete,
        "raw_artifact_reads_required": False,
        "raw_artifact_read_policy": (
            "Use `agentera plan --format json` entries, summary, source, and source_contract before raw PLAN.md access. "
            "When complete_for_plan_artifact is true, do not read `.agentera/plan.yaml` for normal plan startup/evaluation context."
        ),
        "included_state": [
            "header",
            "what",
            "why",
            "constraints",
            "scope",
            "design",
            "tasks",
            "task dependencies",
            "task acceptance criteria",
            "task evidence",
            "overall_acceptance",
            "surprises",
            "previous_plan_archived",
        ],
        "missing_state": [] if complete else ["PLAN.md artifact"],
        "fallback": [] if complete else ["agentera docs --format json"],
        "summary_fields": sorted(summary),
        "entry_fields": ["number", "name", "depends_on", "status", "acceptance", "evidence", "blocked_reason"],
    }


def _startup_completeness_contract() -> dict[str, Any]:
    complete = not STARTUP_COMPLETENESS_MISSING_STATE
    return {
        "complete_for_capability_startup": complete,
        "raw_artifact_reads_required": False,
        "raw_artifact_read_policy": (
            "Do not read raw artifacts when complete_for_capability_startup is true. "
            "When incomplete, try cli_fallback first; raw artifact reads are only a last-resort fallback."
        ),
        "available_state": STARTUP_COMPLETENESS_AVAILABLE_STATE,
        "missing_state": STARTUP_COMPLETENESS_MISSING_STATE,
        "confidence_caveats": STARTUP_COMPLETENESS_CONFIDENCE_CAVEATS,
        "cli_fallback": STARTUP_COMPLETENESS_CLI_FALLBACK,
    }


def _capability_artifact_needs(capability: str) -> tuple[list[str], str | None]:
    capability_dir = _model_path(_active_app_model(), "skillRoot") / "capabilities" / capability
    path = capability_dir / "schemas" / "artifacts.yaml"
    if not path.is_file():
        return [], f"No capability artifact schema found for {capability}."
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except Exception as exc:
        return [], f"Capability artifact schema for {capability} could not be read: {exc}"
    artifacts = data.get("ARTIFACTS") if isinstance(data, dict) else None
    if not isinstance(artifacts, dict):
        return [], f"Capability artifact schema for {capability} has no ARTIFACTS mapping."
    needs: list[str] = []
    for entry in artifacts.values():
        if not isinstance(entry, dict):
            continue
        artifact_id = str(entry.get("artifact_id", "")).strip()
        if artifact_id and artifact_id not in needs:
            needs.append(artifact_id)
    return needs, None


def _capability_context(capability: str | None) -> dict[str, Any] | None:
    if not capability:
        return None
    needs, error = _capability_artifact_needs(capability)
    missing = [name for name in needs if name not in STARTUP_ENVELOPE_STATE_FAMILIES]
    cli_fallback = [
        STATE_FAMILY_FALLBACK_COMMANDS[name]
        for name in missing
        if name in STATE_FAMILY_FALLBACK_COMMANDS
    ]
    return {
        "capability": capability,
        "declared_state_needs": needs,
        "included_state_families": [name for name in needs if name in STARTUP_ENVELOPE_STATE_FAMILIES],
        "missing_state_families": missing,
        "cli_fallback": cli_fallback,
        "raw_artifact_read_policy": (
            "Use the included state families from this hej response first. "
            "If needed families are missing or CLI state is incomplete, run the CLI fallback commands before raw file access."
        ),
        "schema_error": error,
    }


def _task_ref(task: dict[str, Any]) -> dict[str, Any]:
    return {
        "number": task.get("number"),
        "name": _first_present(task, ["name", "title"], ""),
        "status": _entry_status(task, "pending"),
    }


def _orchestration_task_summary(task: dict[str, Any]) -> dict[str, Any]:
    evidence = task.get("evidence")
    evidence_items = evidence if isinstance(evidence, list) else ([] if evidence in (None, "") else [evidence])
    return {
        **_task_ref(task),
        "depends_on": _as_list(task.get("depends_on")),
        "acceptance_summary": {
            "count": len(_as_list(task.get("acceptance"))),
            "items": _as_list(task.get("acceptance")),
        },
        "evidence_summary": {
            "count": len(evidence_items),
            "items": evidence_items,
        },
    }


def _has_recorded_value(value: Any) -> bool:
    if value is None:
        return False
    if isinstance(value, str):
        return bool(value.strip())
    if isinstance(value, (list, dict)):
        return bool(value)
    return True


def _progress_verification_summary(progress: dict[str, Any]) -> dict[str, Any]:
    source = {
        "source_family": "progress",
        "command": "agentera progress --format json",
    }
    if not progress.get("exists"):
        return {
            "status": "unavailable",
            "source_provenance": source,
            "cycle": None,
            "verified_present": False,
            "non_empty_evidence_present": False,
            "non_empty_evidence_fields": [],
            "verified": None,
            "verification_summary": None,
            "latest_progress_verification_pointer": None,
            "caveats": ["No progress cycles are recorded in CLI progress state."],
        }

    latest = progress.get("latest") if isinstance(progress.get("latest"), dict) else {}
    verified = latest.get("verified")
    verified_present = _has_recorded_value(verified)
    cycle = {
        key: latest.get(key)
        for key in ("number", "timestamp", "type", "phase")
        if latest.get(key) not in (None, "")
    }
    pointer = {
        **source,
        "cycle_number": latest.get("number"),
        "field": "verified",
    }
    caveats = [] if verified_present else ["Latest progress cycle has no non-empty verified evidence."]
    evidence_fields = ["verified"] if verified_present else []
    return {
        "status": "available",
        "source_provenance": source,
        "cycle": cycle,
        "verified_present": verified_present,
        "non_empty_evidence_present": verified_present,
        "non_empty_evidence_fields": evidence_fields,
        "verified": verified if verified_present else None,
        "verification_summary": verified if verified_present else None,
        "latest_progress_verification_pointer": pointer,
        "caveats": caveats,
    }


_TARGET_VERSION_RE = re.compile(r"\b\d+\.\d+\.\d+\b")


def _selected_target_version(plan: dict[str, Any]) -> str | None:
    text_parts = [str(plan.get("title", "") or "")]
    first_pending = plan.get("first_pending")
    if isinstance(first_pending, dict):
        text_parts.extend(str(first_pending.get(key, "") or "") for key in ("name", "title"))
    for task in _as_list(plan.get("tasks")):
        if isinstance(task, dict):
            text_parts.extend(str(task.get(key, "") or "") for key in ("name", "title"))
    match = _TARGET_VERSION_RE.search("\n".join(text_parts))
    return match.group(0) if match else None


def _changelog_records_target(text: str, target_version: str | None) -> bool:
    if not target_version:
        return False
    target_re = re.compile(rf"(?<![\d.]){re.escape(target_version)}(?![\d.+-])")
    return any(target_re.search(line) for line in text.splitlines())


def _source_provenance(source_family: str, command: str, field: str | None = None) -> dict[str, Any]:
    provenance: dict[str, Any] = {
        "source_family": source_family,
        "command": command,
    }
    if field:
        provenance["field"] = field
    return provenance


def _docs_conventions(docs: dict[str, Any]) -> dict[str, Any]:
    conventions = docs.get("conventions")
    return conventions if isinstance(conventions, dict) else {}


def _closeout_artifact_mappings(docs: dict[str, Any]) -> dict[str, Any]:
    mapping = _as_list(docs.get("mapping"))
    caveats = [] if docs.get("exists") and mapping else ["Docs artifact mappings are unavailable or empty in CLI docs state."]
    return {
        "status": "available" if docs.get("exists") and mapping else "unavailable",
        "source_provenance": _source_provenance("docs", "agentera docs --format json", "summary.mapping"),
        "entries": mapping,
        "mapping_entries": len(mapping),
        "caveats": caveats,
    }


def _closeout_version_policy(docs: dict[str, Any]) -> dict[str, Any]:
    conventions = _docs_conventions(docs)
    semver_policy = conventions.get("semver_policy") if isinstance(conventions.get("semver_policy"), dict) else {}
    version_files = _as_list(conventions.get("version_files"))
    registry = conventions.get("version_files_registry")
    available = bool(semver_policy)
    caveats = [] if available else ["Docs version policy is unavailable in CLI docs state."]
    return {
        "status": "available" if available else "unavailable",
        "source_provenance": _source_provenance("docs", "agentera docs --format json", "summary.conventions"),
        "version_files": version_files,
        "version_files_registry": registry,
        "semver_policy": semver_policy,
        "caveats": caveats,
    }


def _closeout_todo_blockers(schemas: dict, todo_items: list[dict[str, str]]) -> dict[str, Any]:
    info = schemas.get("todo", {"path": "TODO.md", "fields": {}})
    path = _artifact_path(info, "todo")
    exists = path.exists()
    caveats = [] if exists else ["TODO state is unavailable in CLI state."]
    return {
        "status": "available" if exists else "unavailable",
        "source_provenance": _source_provenance("todo", "agentera todo --format json"),
        "open_count": len(todo_items),
        "items": todo_items,
        "caveats": caveats,
    }


def _closeout_changelog_boundary(schemas: dict, plan: dict[str, Any]) -> dict[str, Any]:
    info = schemas.get("changelog", {"path": "CHANGELOG.md", "fields": {}})
    path = _artifact_path(info, "changelog")
    source = _source_metadata("changelog", path)
    target_version = _selected_target_version(plan)
    if not path.exists():
        return {
            "status": "unavailable",
            "source": source,
            "source_provenance": _source_provenance("changelog", "agentera query changelog --format json"),
            "selected_target_version": target_version,
            "selected_target_recorded": False,
            "unreleased_present": False,
            "latest_release_heading": None,
            "boundary_present": False,
            "boundary": None,
            "caveats": ["CHANGELOG state is unavailable in CLI state."],
        }
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return {
            "status": "unavailable",
            "source": source,
            "source_provenance": _source_provenance("changelog", "agentera query changelog --format json"),
            "selected_target_version": target_version,
            "selected_target_recorded": False,
            "unreleased_present": False,
            "latest_release_heading": None,
            "boundary_present": False,
            "boundary": None,
            "caveats": [f"CHANGELOG state could not be read by the CLI: {exc}"],
        }

    headings = [line.strip() for line in text.splitlines() if line.startswith("## ")]
    unreleased = next((heading for heading in headings if "unreleased" in heading.lower()), None)
    latest_release = next((heading for heading in headings if "unreleased" not in heading.lower()), None)
    selected_recorded = _changelog_records_target(text, target_version)
    caveats: list[str] = []
    if not headings:
        caveats.append("CHANGELOG state has no release headings.")
    if target_version and not selected_recorded:
        caveats.append(f"CHANGELOG state has no {target_version} closeout entry yet.")
    boundary = unreleased or latest_release
    return {
        "status": "available" if headings else "incomplete",
        "source": source,
        "source_provenance": {
            **_source_provenance("changelog", "agentera query changelog --format json", "release_headings"),
            "internal_source": "CLI-resolved CHANGELOG.md heading scan",
        },
        "selected_target_version": target_version,
        "selected_target_recorded": selected_recorded,
        "unreleased_present": unreleased is not None,
        "latest_release_heading": latest_release,
        "boundary_present": boundary is not None,
        "boundary": boundary,
        "release_state": "selected_target_recorded" if selected_recorded else "no_selected_target_closeout_entry",
        "caveats": caveats,
    }


def _closeout_benchmark_evidence(docs: dict[str, Any]) -> dict[str, Any]:
    coverage = docs.get("coverage") if isinstance(docs.get("coverage"), dict) else {}
    tests_summary = str(coverage.get("tests", "") or "").strip()
    if tests_summary and "benchmark" in tests_summary.lower():
        return {
            "status": "available",
            "source_provenance": _source_provenance("docs", "agentera docs --format json", "summary.coverage.tests"),
            "summary_present": True,
            "non_empty_evidence_present": True,
            "history_scope": "cli_visible_summary",
            "user_local_benchmark_reads_required": False,
            "summary": tests_summary,
            "caveats": [],
        }
    return {
        "status": "unavailable",
        "source_provenance": _source_provenance("docs", "agentera docs --format json", "summary.coverage.tests"),
        "summary_present": False,
        "non_empty_evidence_present": False,
        "history_scope": "not_exposed_by_supported_cli_state",
        "user_local_benchmark_reads_required": False,
        "summary": None,
        "caveats": [
            "Supported CLI/state summaries do not expose benchmark evidence; do not read user-local benchmark files for normal closeout."
        ],
    }


def _local_git_tag_evidence(target_version: str | None) -> dict[str, Any]:
    tag = f"v{target_version}" if target_version else None
    source = {
        "source_family": "local_git",
        "command": "git tag --list <target-tag>",
        "remote": False,
    }
    if not tag:
        return {
            "status": "unavailable",
            "tag": None,
            "source_provenance": source,
            "object_type": None,
            "caveats": ["No selected target version is available for local tag evidence."],
        }
    try:
        result = subprocess.run(
            ["git", "tag", "--list", tag],
            capture_output=True,
            text=True,
            cwd=Path.cwd(),
            timeout=2,
            check=False,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        return {
            "status": "unavailable",
            "tag": tag,
            "source_provenance": source,
            "object_type": None,
            "caveats": [f"Local git tag evidence is unavailable: {exc}"],
        }
    if result.returncode != 0:
        return {
            "status": "unavailable",
            "tag": tag,
            "source_provenance": source,
            "object_type": None,
            "caveats": ["Local git tag evidence is unavailable because this project is not a git worktree."],
        }
    if tag not in result.stdout.splitlines():
        return {
            "status": "absent",
            "tag": tag,
            "source_provenance": source,
            "object_type": None,
            "caveats": [f"Local tag {tag} is not present."],
        }
    object_type = None
    try:
        object_result = subprocess.run(
            ["git", "cat-file", "-t", tag],
            capture_output=True,
            text=True,
            cwd=Path.cwd(),
            timeout=2,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        object_result = None
    if object_result is not None and object_result.returncode == 0:
        object_type = object_result.stdout.strip() or None
    return {
        "status": "available",
        "tag": tag,
        "source_provenance": source,
        "object_type": object_type,
        "caveats": [] if object_type else [f"Local tag {tag} exists but object type could not be verified."],
    }


def _closeout_release_boundary(changelog_boundary: dict[str, Any], bundle: dict[str, Any]) -> dict[str, Any]:
    target_version = changelog_boundary.get("selected_target_version")
    local_tag = _local_git_tag_evidence(str(target_version) if target_version else None)
    metadata_recorded = bool(changelog_boundary.get("selected_target_recorded"))
    caveats = [*changelog_boundary.get("caveats", []), *local_tag.get("caveats", [])]
    if not metadata_recorded and local_tag.get("status") != "available":
        caveats.append("No local closeout metadata or local tag evidence is recorded for the selected target.")
    return {
        "status": "available" if changelog_boundary.get("boundary_present") else "incomplete",
        "selected_target_version": target_version,
        "boundary": changelog_boundary.get("boundary"),
        "local_metadata_evidence": {
            "status": "recorded" if metadata_recorded else "not_recorded",
            "source_provenance": changelog_boundary.get("source_provenance"),
            "field": "changelog_boundary.selected_target_recorded",
        },
        "local_tag_evidence": local_tag,
        "publication_evidence": {
            "package_publication": "not_recorded_in_cli_state",
            "remote_push": "not_recorded_in_cli_state",
            "remote_checks_performed": False,
            "registry_checks_performed": False,
            "source_provenance": _source_provenance(
                "closeout_context",
                "agentera hej --format json --capability-context dokumentera",
                "release_boundary.publication_evidence",
            ),
            "caveats": ["Closeout context does not contact remotes or package registries."],
        },
        "app_refresh_evidence": {
            "installed_app_status": bundle.get("status"),
            "refresh": "not_recorded_in_cli_state",
            "approval_recorded": False,
            "source_provenance": _source_provenance("hej", "agentera hej --format json", "bundle.status"),
        },
        "caveats": caveats,
    }


def _dokumentera_closeout_context(
    capability: str | None,
    schemas: dict,
    plan: dict[str, Any],
    progress: dict[str, Any],
    todo_items: list[dict[str, str]],
    docs: dict[str, Any],
    profile: dict[str, Any],
    bundle: dict[str, Any],
) -> dict[str, Any] | None:
    if capability != "dokumentera":
        return None

    capability_contract = _capability_context(capability) or {}
    artifact_mappings = _closeout_artifact_mappings(docs)
    version_policy = _closeout_version_policy(docs)
    todo_blockers = _closeout_todo_blockers(schemas, todo_items)
    changelog_boundary = _closeout_changelog_boundary(schemas, plan)
    progress_evidence = _progress_verification_summary(progress)
    benchmark_evidence = _closeout_benchmark_evidence(docs)
    release_boundary = _closeout_release_boundary(changelog_boundary, bundle)

    required_state = {
        "artifact_mappings": artifact_mappings["status"] == "available",
        "version_policy": version_policy["status"] == "available",
        "todo_blockers": todo_blockers["status"] == "available",
        "changelog_boundary": changelog_boundary["boundary_present"],
        "progress_evidence": progress_evidence["status"] == "available",
        "benchmark_evidence_or_caveat": benchmark_evidence["status"] == "available" or bool(benchmark_evidence["caveats"]),
    }
    missing_required = [name for name, present in required_state.items() if not present]

    state_caveats: list[str] = []
    for family in capability_contract.get("missing_state_families", []):
        state_caveats.append(f"{family} state is not included in hej startup context.")
    for component in (
        artifact_mappings,
        version_policy,
        todo_blockers,
        changelog_boundary,
        release_boundary,
        progress_evidence,
        benchmark_evidence,
    ):
        state_caveats.extend(component.get("caveats", []))
    if bundle.get("status") != "fresh":
        state_caveats.append("Agentera app state is not fresh; this is a caveat, not approval to refresh installed apps.")
    if profile.get("status") != "loaded":
        state_caveats.append("profile-derived state is unavailable in hej context.")
    elif profile.get("stale") is True:
        state_caveats.append("profile-derived state is stale; this is a caveat, not approval to refresh profile state.")
    state_caveats = list(dict.fromkeys(state_caveats))

    fallback_commands = list(dict.fromkeys([
        "agentera todo --format json",
        "agentera docs --format json",
        "agentera progress --format json",
        "agentera query changelog --format json",
        "agentera query --list-artifacts",
        *capability_contract.get("cli_fallback", []),
    ]))
    complete = not missing_required
    caveated = bool(state_caveats)
    return {
        "capability": "dokumentera",
        "artifact_mappings": artifact_mappings,
        "version_policy": version_policy,
        "todo_blockers": todo_blockers,
        "changelog_boundary": changelog_boundary,
        "release_boundary": release_boundary,
        "progress_evidence": progress_evidence,
        "benchmark_evidence": benchmark_evidence,
        "state_family_caveats": state_caveats,
        "fallback_commands": fallback_commands,
        "source_contract": {
            "complete_for_closeout_context": complete,
            "caveated": caveated,
            "raw_artifact_reads_required": False,
            "raw_artifact_read_policy": (
                "Use this closeout_context and included hej state first. Run listed routine/query CLI fallback commands "
                "for missing or incomplete closeout state; raw artifact reads are last-resort diagnostics, not normal closeout behavior."
            ),
            "included_state_families": capability_contract.get("included_state_families", []),
            "missing_state_families": capability_contract.get("missing_state_families", []),
            "closeout_state_families": [
                "docs",
                "todo",
                "changelog",
                "progress",
                "benchmark_evidence",
            ],
            "required_closeout_state": required_state,
            "missing_required_closeout_state": missing_required,
            "fallback_commands": fallback_commands,
            "caveats": state_caveats,
            "owns": [
                "artifact mappings",
                "version policy",
                "TODO blockers",
                "changelog or no-release boundary",
                "local metadata/tag versus publication boundary",
                "latest progress evidence",
                "benchmark evidence pointer or unavailable caveat",
                "provenance pointers and non-empty evidence flags",
                "fallback commands",
                "raw-read policy",
                "truthful completeness flag",
            ],
        },
    }


def _dependency_ready_tasks(tasks: list[dict[str, Any]]) -> list[dict[str, Any]]:
    task_by_number = {task.get("number"): task for task in tasks if task.get("number") is not None}
    ready: list[dict[str, Any]] = []
    for task in tasks:
        status = _entry_status(task, "pending")
        if status in DONE_STATUSES or status in BLOCKED_STATUSES:
            continue
        blocked = False
        for dep in _as_list(task.get("depends_on")):
            dependency = task_by_number.get(dep)
            if dependency is None or _entry_status(dependency, "pending") not in DONE_STATUSES:
                blocked = True
                break
        if not blocked:
            ready.append(task)
    return ready


def _select_evidence_target(plan: dict[str, Any]) -> dict[str, Any]:
    tasks = [task for task in _as_list(plan.get("tasks")) if isinstance(task, dict)]
    no_target = {
        "status": "no_target",
        "target_type": "repository",
        "task": None,
        "selection_reason": "no_plan_task_target",
        "source_provenance": _source_provenance("plan", "agentera plan --format json", "entries"),
        "caveats": ["No plan task target was selected; evaluate repository-level evidence only."],
    }
    if not plan.get("exists") or not tasks:
        return no_target

    in_progress = next((task for task in tasks if _entry_status(task, "pending") == "in_progress"), None)
    if in_progress:
        return {
            "status": "selected",
            "target_type": "plan_task",
            "task": _task_ref(in_progress),
            "selection_reason": "in_progress_task",
            "source_provenance": _source_provenance("plan", "agentera plan --format json", "entries.status"),
            "caveats": [],
        }

    ready = _dependency_ready_tasks(tasks)
    if ready:
        return {
            "status": "selected",
            "target_type": "plan_task",
            "task": _task_ref(ready[0]),
            "selection_reason": "first_dependency_ready_pending_task",
            "source_provenance": _source_provenance("plan", "agentera plan --format json", "entries.depends_on"),
            "caveats": [],
        }

    completed_with_evidence = next(
        (
            task for task in reversed(tasks)
            if _entry_status(task, "pending") in DONE_STATUSES and _has_recorded_value(task.get("evidence"))
        ),
        None,
    )
    if completed_with_evidence:
        return {
            "status": "selected",
            "target_type": "plan_task",
            "task": _task_ref(completed_with_evidence),
            "selection_reason": "latest_completed_task_with_evidence",
            "source_provenance": _source_provenance("plan", "agentera plan --format json", "entries.evidence"),
            "caveats": [],
        }
    return no_target


def _evidence_plan_criteria(plan: dict[str, Any], target: dict[str, Any]) -> dict[str, Any]:
    task_ref = target.get("task") if isinstance(target.get("task"), dict) else None
    selected = None
    if task_ref:
        tasks = [task for task in _as_list(plan.get("tasks")) if isinstance(task, dict)]
        selected = next((task for task in tasks if task.get("number") == task_ref.get("number")), None)
    criteria = _as_list(selected.get("acceptance")) if isinstance(selected, dict) else []
    return {
        "status": "available" if criteria else "incomplete",
        "source_provenance": _source_provenance("plan", "agentera plan --format json", "entries.acceptance"),
        "target": task_ref,
        "criteria": criteria,
        "criteria_count": len(criteria),
        "non_empty_evidence_present": bool(criteria),
        "non_empty_evidence_fields": ["criteria"] if criteria else [],
        "caveats": [] if criteria else ["Selected evaluation target has no acceptance criteria in CLI plan state."],
    }


def _evidence_docs_state(docs: dict[str, Any]) -> dict[str, Any]:
    available = bool(docs.get("exists"))
    non_empty_fields = [
        field for field in ("mapping_entries", "indexed_documents", "last_audit")
        if _has_recorded_value(docs.get(field))
    ]
    freshness, freshness_caveat = _freshness_state(docs.get("last_audit"), "Docs")
    return {
        "status": "available" if available else "unavailable",
        "source_provenance": _source_provenance("docs", "agentera docs --format json"),
        "mapping_entries": docs.get("mapping_entries", 0),
        "indexed_documents": docs.get("indexed_documents", 0),
        "last_audit": docs.get("last_audit"),
        "freshness": freshness,
        "non_empty_evidence_present": bool(non_empty_fields),
        "non_empty_evidence_fields": non_empty_fields,
        "caveats": (["Docs state is unavailable in CLI docs state."] if not available else [])
        + ([freshness_caveat] if available and freshness_caveat else []),
    }


def _evidence_health_state(health: dict[str, Any]) -> dict[str, Any]:
    available = bool(health.get("exists"))
    non_empty_fields = [
        field for field in ("audit_number", "trajectory", "grade")
        if _has_recorded_value({"audit_number": health.get("number"), **health}.get(field))
    ]
    freshness, freshness_caveat = _freshness_state(health.get("timestamp"), "Health")
    return {
        "status": "available" if available else "unavailable",
        "source_provenance": _source_provenance("health", "agentera health --format json"),
        "audit_number": health.get("number"),
        "timestamp": health.get("timestamp"),
        "trajectory": health.get("trajectory"),
        "grade": health.get("grade"),
        "degrading": bool(health.get("degrading")),
        "freshness": freshness,
        "non_empty_evidence_present": bool(non_empty_fields),
        "non_empty_evidence_fields": non_empty_fields,
        "caveats": (["Health state is unavailable in CLI health state."] if not available else [])
        + ([freshness_caveat] if available and freshness_caveat else []),
    }


def _freshness_state(value: Any, label: str, stale_after_days: int = 30) -> tuple[str, str | None]:
    if not isinstance(value, str) or not value.strip():
        return "unknown", None
    try:
        observed = date.fromisoformat(value.strip()[:10])
    except ValueError:
        return "unknown", f"{label} freshness date is not ISO-parseable in CLI state."
    age_days = (date.today() - observed).days
    if age_days > stale_after_days:
        return "stale", f"{label} evidence is stale ({age_days} days old; threshold={stale_after_days})."
    return "current", None


def _evidence_todo_state(schemas: dict, todo_items: list[dict[str, str]]) -> dict[str, Any]:
    info = schemas.get("todo", {"path": "TODO.md", "fields": {}})
    exists = _artifact_path(info, "todo").exists()
    return {
        "status": "available" if exists else "unavailable",
        "source_provenance": _source_provenance("todo", "agentera todo --format json"),
        "open_count": len(todo_items),
        "items": todo_items,
        "non_empty_evidence_present": bool(todo_items),
        "non_empty_evidence_fields": ["items"] if todo_items else [],
        "caveats": [] if exists else ["TODO state is unavailable in CLI TODO state."],
    }


def _evidence_protected_state_checks() -> dict[str, Any]:
    source = _source_provenance(
        "evidence_context",
        "agentera hej --format json --capability-context inspektera",
        "protected_state_checks",
    )
    return {
        "status": "not_checked_by_design",
        "allowed_status_values": ["verified_local", "not_checked_by_design", "requires_manual_check", "unavailable"],
        "source_provenance": source,
        "checks": [
            {
                "name": "vision_state",
                "status": "not_checked_by_design",
                "protected": True,
                "checked": False,
                "source_provenance": source,
                "caveats": ["Vision state is protected during execution cycles and was not read or modified."],
            },
            {
                "name": "objective_state",
                "status": "not_checked_by_design",
                "protected": True,
                "checked": False,
                "source_provenance": source,
                "caveats": ["Objective state is protected during execution cycles and was not read or modified."],
            },
        ],
        "caveats": [
            "Protected-state boundaries are reported without reading or modifying vision or objective state."
        ],
    }


def _evidence_version_checks(docs: dict[str, Any]) -> dict[str, Any]:
    conventions = _docs_conventions(docs)
    version_files = _as_list(conventions.get("version_files"))
    semver_policy = conventions.get("semver_policy") if isinstance(conventions.get("semver_policy"), dict) else {}
    source = _source_provenance("docs", "agentera docs --format json", "summary.conventions")
    checks = [
        {
            "name": "docs_version_policy",
            "status": "verified_local" if semver_policy else "unavailable",
            "source_provenance": source,
            "evidence": {"semver_policy": semver_policy},
            "caveats": [] if semver_policy else ["Docs semver policy is unavailable in CLI docs state."],
        },
        {
            "name": "version_files",
            "status": "verified_local" if version_files else "unavailable",
            "source_provenance": source,
            "evidence": {"version_files": version_files},
            "caveats": [] if version_files else ["Docs version files are unavailable in CLI docs state."],
        },
        {
            "name": "publication_evidence",
            "status": "requires_manual_check",
            "source_provenance": _source_provenance("evidence_context", "agentera hej --format json --capability-context inspektera", "version_checks.publication_evidence"),
            "remote_checks_performed": False,
            "registry_checks_performed": False,
            "caveats": ["Publication and registry evidence is not recorded in CLI evidence context and requires manual verification if needed."],
        },
        {
            "name": "remote_push_evidence",
            "status": "requires_manual_check",
            "source_provenance": _source_provenance("evidence_context", "agentera hej --format json --capability-context inspektera", "version_checks.remote_push_evidence"),
            "remote_checks_performed": False,
            "caveats": ["Remote push evidence is not recorded in CLI evidence context and requires manual verification if needed."],
        },
        {
            "name": "installed_app_refresh",
            "status": "not_checked_by_design",
            "source_provenance": _source_provenance("evidence_context", "agentera hej --format json --capability-context inspektera", "version_checks.installed_app_refresh"),
            "refresh_performed": False,
            "caveats": ["Installed app refresh state is deliberately not checked or changed by evidence context."],
        },
    ]
    if any(check["status"] == "requires_manual_check" for check in checks):
        status = "requires_manual_check"
    elif any(check["status"] == "unavailable" for check in checks):
        status = "unavailable"
    else:
        status = "verified_local"
    return {
        "status": status,
        "allowed_status_values": ["verified_local", "not_checked_by_design", "requires_manual_check", "unavailable"],
        "source_provenance": source,
        "checks": checks,
        "caveats": [caveat for check in checks for caveat in check.get("caveats", [])],
    }


def _decision_context_risk(schemas: dict) -> dict[str, Any]:
    info = schemas.get("decisions", {"path": ".agentera/decisions.yaml", "fields": {}})
    path = _artifact_path(info, "decisions")
    source = _source_metadata("decisions", path)
    data = _load_named_artifact(schemas, "decisions")
    entries = [_decision_context_entry(entry) for entry in _extract_decision_entries(data)]
    if not source.get("exists"):
        return {
            "status": "unavailable",
            "source_provenance": _source_provenance("decisions", "agentera decisions --format json"),
            "summary": None,
            "caveats": ["Decision state is unavailable in CLI evidence context."],
        }
    contract = _decision_source_contract(source, entries, {})
    compacted = contract["completeness"]["compacted_entries"]
    missing = contract["completeness"]["entries_with_missing_fields"]
    caveats = contract.get("caveats", []) if compacted or missing else []
    return {
        "status": "caveated" if caveats else "available",
        "source_provenance": _source_provenance("decisions", "agentera decisions --format json"),
        "summary": contract["completeness"],
        "caveats": caveats,
    }


def _residual_risk_entry(category: str, status: str, message: str, source_provenance: dict[str, Any]) -> dict[str, Any]:
    return {
        "category": category,
        "status": status,
        "message": message,
        "source_provenance": source_provenance,
    }


def _inspektera_evidence_context(
    capability: str | None,
    schemas: dict,
    plan: dict[str, Any],
    progress: dict[str, Any],
    health: dict[str, Any],
    todo_items: list[dict[str, str]],
    docs: dict[str, Any],
    profile: dict[str, Any],
    bundle: dict[str, Any],
) -> dict[str, Any] | None:
    if capability != "inspektera":
        return None

    capability_contract = _capability_context(capability) or {}
    evaluation_target = _select_evidence_target(plan)
    plan_criteria = _evidence_plan_criteria(plan, evaluation_target)
    progress_verification = _progress_verification_summary(progress)
    docs_state = _evidence_docs_state(docs)
    health_state = _evidence_health_state(health)
    todo_state = _evidence_todo_state(schemas, todo_items)
    protected_state_checks = _evidence_protected_state_checks()
    version_checks = _evidence_version_checks(docs)
    decision_context_risk = _decision_context_risk(schemas)

    state_caveats: list[str] = []
    attributed_risks: list[dict[str, Any]] = []
    for family in capability_contract.get("missing_state_families", []):
        message = f"{family} state is not included in hej startup context."
        state_caveats.append(message)
        attributed_risks.append(_residual_risk_entry(
            "missing_state_family",
            "caveated",
            message,
            _source_provenance("hej", "agentera hej --format json --capability-context inspektera", "source_contract.capability_context.missing_state_families"),
        ))
    if bundle.get("status") != "fresh":
        message = "Agentera app state is not fresh; this is a caveat, not approval to refresh installed apps."
        state_caveats.append(message)
        attributed_risks.append(_residual_risk_entry(
            "installed_app_state",
            "caveated",
            message,
            _source_provenance("hej", "agentera hej --format json", "bundle.status"),
        ))
    if profile.get("status") != "loaded":
        message = "profile-derived state is unavailable in hej context."
        state_caveats.append(message)
        attributed_risks.append(_residual_risk_entry(
            "profile_state",
            "unavailable",
            message,
            _source_provenance("hej", "agentera hej --format json", "profile.status"),
        ))
    elif profile.get("stale") is True:
        message = "profile-derived state is stale; this is a caveat, not approval to refresh profile state."
        state_caveats.append(message)
        attributed_risks.append(_residual_risk_entry(
            "profile_state",
            "caveated",
            message,
            _source_provenance("hej", "agentera hej --format json", "profile.stale"),
        ))
    for component in (evaluation_target, plan_criteria, progress_verification, docs_state, health_state, todo_state, protected_state_checks, version_checks):
        for caveat in component.get("caveats", []):
            state_caveats.append(caveat)
            attributed_risks.append(_residual_risk_entry(
                "evidence_family",
                "caveated",
                caveat,
                component.get("source_provenance", _source_provenance("evidence_context", "agentera hej --format json --capability-context inspektera")),
            ))
    if decision_context_risk.get("caveats"):
        for caveat in decision_context_risk["caveats"]:
            state_caveats.append(caveat)
            attributed_risks.append(_residual_risk_entry(
                "decisions_context",
                decision_context_risk["status"],
                caveat,
                decision_context_risk["source_provenance"],
            ))
    retry_state = _retry_state()
    for caveat in retry_state.get("caveats", []):
        state_caveats.append(caveat)
        attributed_risks.append(_residual_risk_entry(
            "retry_state",
            retry_state["status"],
            caveat,
            retry_state["source_provenance"],
        ))
    state_caveats = list(dict.fromkeys(state_caveats))
    deduped_risks = []
    seen_risks: set[tuple[str, str]] = set()
    for risk in attributed_risks:
        key = (risk["category"], risk["message"])
        if key not in seen_risks:
            seen_risks.add(key)
            deduped_risks.append(risk)

    required_state = {
        "evaluation_target": evaluation_target["status"] == "selected",
        "plan_criteria": plan_criteria["status"] == "available",
        "progress_verification": progress_verification["status"] == "available",
        "docs_state": docs_state["status"] == "available",
        "health_state": health_state["status"] == "available",
        "todo_state": todo_state["status"] == "available",
        "source_contract": True,
    }
    missing_required = [name for name, present in required_state.items() if not present]
    fallback_commands = list(dict.fromkeys([
        "agentera plan --format json",
        "agentera progress --format json",
        "agentera docs --format json",
        "agentera health --format json",
        "agentera todo --format json",
        "agentera query --list-artifacts",
        *capability_contract.get("cli_fallback", []),
    ]))
    return {
        "capability": "inspektera",
        "evaluation_target": evaluation_target,
        "plan_criteria": plan_criteria,
        "progress_verification": progress_verification,
        "docs_state": docs_state,
        "health_state": health_state,
        "todo_state": todo_state,
        "protected_state_checks": protected_state_checks,
        "version_checks": version_checks,
        "decision_context": decision_context_risk,
        "residual_risks": {
            "status": "caveated" if deduped_risks else "none_recorded",
            "items": state_caveats,
            "attributed_items": deduped_risks,
            "caveats": [],
        },
        "state_family_caveats": state_caveats,
        "fallback_commands": fallback_commands,
        "source_contract": {
            "complete_for_evidence_context": not missing_required,
            "caveated": bool(state_caveats),
            "raw_artifact_reads_required": False,
            "raw_artifact_read_policy": (
                "Use this evidence_context and included hej state first. Run listed routine/query CLI fallback commands "
                "for missing or incomplete evidence state; raw artifact reads are last-resort diagnostics, not normal evaluation startup behavior."
            ),
            "included_state_families": capability_contract.get("included_state_families", []),
            "missing_state_families": capability_contract.get("missing_state_families", []),
            "required_evidence_state": required_state,
            "missing_required_evidence_state": missing_required,
            "fallback_commands": fallback_commands,
            "caveats": state_caveats,
            "owns": [
                "evaluation target",
                "plan criteria",
                "progress verification",
                "docs state",
                "health state",
                "TODO state",
                "protected-state placeholder checks",
                "version boundary checks",
                "compacted decision caveats",
                "attributed residual risks",
                "fallback commands",
                "raw-read policy",
                "truthful completeness metadata",
            ],
            "deferred": [],
        },
    }


def _retry_state() -> dict[str, Any]:
    return {
        "status": "not_recorded",
        "source_provenance": {
            "source_family": "progress",
            "command": "agentera progress --format json",
            "reason": "Current CLI/artifact state records progress cycles but no retry attempt state for orchestration tasks.",
        },
        "caveats": ["Retry attempt state is not recorded; no attempt count is exposed."],
    }


def _evaluator_handoff(
    selected: dict[str, Any] | None,
    progress_verification: dict[str, Any],
    retry_state: dict[str, Any],
    state_caveats: list[str],
) -> dict[str, Any]:
    caveats = [*state_caveats, *progress_verification.get("caveats", []), *retry_state.get("caveats", [])]
    if selected is None:
        caveats.append("No dependency-ready task is selected for evaluator handoff.")
        return {
            "status": "unavailable",
            "task": None,
            "acceptance_criteria": [],
            "evidence_requirements": [],
            "latest_progress_verification_pointer": progress_verification.get("latest_progress_verification_pointer"),
            "evaluation_caveats": caveats,
        }

    evidence_requirements = selected.get("evidence_summary", {}).get("items", [])
    if not evidence_requirements:
        caveats.append("Selected task has no explicit evidence requirements recorded in plan state.")
    return {
        "status": "ready",
        "task": _task_ref(selected),
        "acceptance_criteria": selected.get("acceptance_summary", {}).get("items", []),
        "evidence_requirements": evidence_requirements,
        "latest_progress_verification_pointer": progress_verification.get("latest_progress_verification_pointer"),
        "evaluation_caveats": caveats,
    }


def _orchestration_context(
    capability: str | None,
    plan: dict[str, Any],
    progress: dict[str, Any],
    health: dict[str, Any],
    todo_items: list[dict[str, str]],
    docs: dict[str, Any],
    profile: dict[str, Any],
    next_action: dict[str, str],
) -> dict[str, Any] | None:
    if capability != "orkestrera":
        return None

    tasks = [task for task in _as_list(plan.get("tasks")) if isinstance(task, dict)]
    task_by_number = {task.get("number"): task for task in tasks if task.get("number") is not None}
    dependency_ready: list[dict[str, Any]] = []
    blocked: list[dict[str, Any]] = []

    for task in tasks:
        status = _entry_status(task, "pending")
        if status in DONE_STATUSES:
            continue
        reasons: list[str] = []
        if status in BLOCKED_STATUSES:
            reasons.append(f"task status is {status}")
        for dep in _as_list(task.get("depends_on")):
            dependency = task_by_number.get(dep)
            if dependency is None:
                reasons.append(f"dependency {dep} is not present in plan tasks")
            elif _entry_status(dependency, "pending") not in DONE_STATUSES:
                reasons.append(f"dependency {dep} is {_entry_status(dependency, 'pending')}")
        if reasons:
            blocked.append({**_orchestration_task_summary(task), "blocked_reasons": reasons})
        else:
            dependency_ready.append(_orchestration_task_summary(task))

    selected = dependency_ready[0] if dependency_ready else None
    state_caveats: list[str] = []
    fallback_commands: list[str] = []
    capability_contract = _capability_context(capability) or {}
    for family in capability_contract.get("missing_state_families", []):
        state_caveats.append(f"{family} state is not included in hej startup context.")
    fallback_commands.extend(capability_contract.get("cli_fallback", []))

    if not plan.get("exists"):
        state_caveats.append("plan state is unavailable; task queue cannot be complete.")
        fallback_commands.append("agentera plan --format json")
    if not progress.get("exists"):
        state_caveats.append("progress state is unavailable; latest verification is not summarized here.")
        fallback_commands.append("agentera progress --format json")
    if not health.get("exists"):
        state_caveats.append("health state is unavailable or incomplete.")
        fallback_commands.append("agentera health --format json")
    if not docs.get("exists"):
        state_caveats.append("docs mapping state is unavailable or incomplete.")
        fallback_commands.append("agentera docs --format json")
    if not todo_items:
        state_caveats.append("todo state has no open entries in hej context; absence may mean none open or unavailable.")
        fallback_commands.append("agentera todo --format json")
    if profile.get("status") != "loaded":
        state_caveats.append("profile-derived state is unavailable in hej context.")
    elif profile.get("stale") is True:
        state_caveats.append("profile-derived state is stale; this is a caveat, not approval to refresh installed apps or profile state.")

    fallback_commands = list(dict.fromkeys(fallback_commands))
    progress_verification = _progress_verification_summary(progress)
    retry_state = _retry_state()
    evaluator_handoff = _evaluator_handoff(selected, progress_verification, retry_state, state_caveats)
    complete = bool(plan.get("exists")) and bool(tasks) and not state_caveats
    return {
        "capability": "orkestrera",
        "task_queue": {
            "total": len(tasks),
            "dependency_ready_tasks": dependency_ready,
            "blocked_tasks": blocked,
        },
        "selected_next_task": selected,
        "selected_next_action": next_action,
        "progress_verification": progress_verification,
        "retry_state": retry_state,
        "evaluator_handoff": evaluator_handoff,
        "task_summaries": [_orchestration_task_summary(task) for task in tasks],
        "state_family_caveats": state_caveats,
        "fallback_commands": fallback_commands,
        "source_contract": {
            "complete_for_orchestration_context": complete,
            "raw_artifact_reads_required": False,
            "raw_artifact_read_policy": (
                "Use this orchestration_context and included hej state first. Run listed routine CLI fallback commands "
                "for missing or incomplete state families; raw artifact reads are last-resort diagnostics, not normal startup behavior."
            ),
            "included_state_families": capability_contract.get("included_state_families", []),
            "missing_state_families": capability_contract.get("missing_state_families", []),
            "fallback_commands": fallback_commands,
            "caveats": state_caveats,
            "owns": [
                "dependency-ready task queue",
                "blocked task reasons",
                "selected next task",
                "task acceptance summaries",
                "task evidence summaries",
                "latest progress verification summary",
                "retry_state provenance",
                "evaluator handoff inputs",
                "state-family caveats",
            ],
            "deferred": [],
        },
    }


def _contract_path() -> Path:
    return Path(__file__).resolve().parent.parent / "references" / "cli" / "agent-ready-state-contract.yaml"


def _load_decision45_contract() -> tuple[dict[str, Any] | None, str | None]:
    path = _contract_path()
    if not path.is_file():
        return None, "Decision 45 CLI contract is missing"
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except Exception as exc:
        return None, f"Decision 45 CLI contract could not be read: {exc}"
    if not isinstance(data, dict):
        return None, "Decision 45 CLI contract did not parse as a mapping"
    return data, None


def _schema_field_description(entry: dict[str, Any]) -> dict[str, Any]:
    return {
        "id": entry.get("id"),
        "field": entry.get("field"),
        "type": entry.get("type", "unknown"),
        "required": entry.get("required", "unknown"),
        "format": entry.get("format"),
        "validation": entry.get("validation", []),
    }


def _describe_schema_fields(schema: dict[str, Any]) -> list[dict[str, Any]]:
    skip = {
        "meta", "GROUP_PREFIXES", "BUDGET", "COMPACTION", "VALIDATION",
        "ARCHIVE",
    }
    fields: list[dict[str, Any]] = []
    for group_key, group_val in schema.items():
        if group_key in skip or not isinstance(group_val, dict):
            continue
        for _num, entry in group_val.items():
            if isinstance(entry, dict) and "field" in entry:
                field = _schema_field_description(entry)
                field["group"] = group_key
                fields.append(field)
    return fields


def _describe_artifact_schemas(
    schemas_dir: Path,
    schemas: dict[str, dict[str, Any]],
    model: dict[str, Path | str],
) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
    gaps: list[dict[str, Any]] = []
    if not schemas_dir.is_dir():
        gaps.append({
            "scope": "artifact_schemas",
            "status": "missing",
            "message": _surface_missing_message("artifact schema directory", schemas_dir, model),
        })
        return [], gaps

    artifacts: list[dict[str, Any]] = []
    for name in sorted(schemas):
        info = schemas[name]
        schema = info.get("schema") if isinstance(info.get("schema"), dict) else {}
        meta = schema.get("meta", {}) if isinstance(schema, dict) else {}
        schema_file = schemas_dir / f"{name}.yaml"
        artifacts.append({
            "name": name,
            "status": "discovered" if meta else "unknown_metadata",
            "schema_file": str(schema_file) if schema_file.is_file() else None,
            "path": info.get("path") or "unknown",
            "artifact_type": meta.get("artifact_type", "unknown") if isinstance(meta, dict) else "unknown",
            "format": meta.get("format", "unknown") if isinstance(meta, dict) else "unknown",
            "producer": meta.get("producer", "unknown") if isinstance(meta, dict) else "unknown",
            "consumers": meta.get("consumers", "unknown") if isinstance(meta, dict) else "unknown",
            "fields": _describe_schema_fields(schema),
        })
        if not meta:
            gaps.append({
                "scope": f"artifact_schemas.{name}",
                "status": "unknown",
                "message": "schema metadata is absent or unreadable",
            })
    return artifacts, gaps


def _command_description(name: str, *, kind: str, fields: list[str] | None = None) -> dict[str, Any]:
    output_formats = ["text", "json", "yaml"]
    if name == "lint":
        output_formats = ["text", "json"]
    elif name in {"compact", "gate"}:
        output_formats = ["text", "json"]
    elif name == "doctor":
        output_formats = ["text", "json"]
    elif name == "upgrade":
        output_formats = ["text", "json"]
    elif name == "describe":
        output_formats = ["json", "yaml"]
    elif name == "prime":
        output_formats = ["text"]
    return {
        "name": name,
        "kind": kind,
        "description": COMMAND_DESCRIPTIONS.get(name, "unknown"),
        "filters": COMMAND_FILTERS.get(name, []),
        "output_formats": output_formats,
        "structured_fields": fields or [],
    }


def _describe_commands() -> list[dict[str, Any]]:
    commands = [_command_description("prime", kind="guidance")]
    for name in ROUTINE_STATE_COMMANDS:
        commands.append(_command_description(name, kind="routine_state", fields=_available_structured_fields(name)))
    commands.extend([
        _command_description("query", kind="advanced_artifact_query"),
        _command_description("lint", kind="artifact_lint", fields=["command", "status", "artifact", "checks", "summary"]),
        _command_description("gate", kind="repo_gate", fields=["command", "status", "project", "summary", "operations"]),
        _command_description("compact", kind="artifact_compaction", fields=["command", "status", "project", "summary", "operations"]),
        _command_description("describe", kind="runtime_introspection"),
        _command_description("upgrade", kind="upgrade"),
        _command_description("doctor", kind="self_check"),
    ])
    return commands


def _contract_section(contract: dict[str, Any] | None, key: str, gaps: list[dict[str, Any]]) -> Any:
    if isinstance(contract, dict) and key in contract:
        return contract[key]
    gaps.append({
        "scope": key,
        "status": "unknown",
        "message": f"Decision 45 contract section {key!r} is unavailable",
    })
    return None


def _build_describe_payload() -> dict[str, Any]:
    contract, contract_error = _load_decision45_contract()
    app_model = _active_app_model()
    schemas_dir = _discover_schemas_dir(app_model)
    schemas = _load_schemas(schemas_dir)
    gaps: list[dict[str, Any]] = []
    if contract_error:
        gaps.append({"scope": "contract", "status": "missing", "message": contract_error})
    artifact_schemas, schema_gaps = _describe_artifact_schemas(schemas_dir, schemas, app_model)
    gaps.extend(schema_gaps)

    slash_aliases = _contract_section(contract, "slash_route_aliases", gaps)
    doctor_contract = _contract_section(contract, "doctor", gaps)
    structured_output = _contract_section(contract, "structured_output", gaps)
    field_selection = _contract_section(contract, "field_selection", gaps)

    return {
        "schemaVersion": "agentera.describe.v1",
        "command": "describe",
        "status": "incomplete" if gaps else "ok",
        "source": {
            "contract": str(_contract_path()),
            "contract_exists": _contract_path().is_file(),
            "schemas_dir": str(schemas_dir),
            "schemas_dir_exists": schemas_dir.is_dir(),
            "schema_count": len(artifact_schemas),
            "app_model": _app_model_payload(app_model),
        },
        "commands": _describe_commands(),
        "routine_state_commands": ROUTINE_STATE_COMMANDS,
        "structured_output": {
            "formats": (structured_output or {}).get("formats", ["json", "yaml"]) if isinstance(structured_output, dict) else "unknown",
            "fields_by_command": {
                "routine_state_commands": ROUTINE_STRUCTURED_FIELDS,
                "hej": HEJ_STRUCTURED_FIELDS,
            },
        },
        "field_selection": {
            "syntax": (field_selection or {}).get("syntax", "--fields FIELD[,FIELD...]") if isinstance(field_selection, dict) else "unknown",
            "retained_context": REQUIRED_SPARSE_CONTEXT_FIELDS,
            "applies_to": (field_selection or {}).get("applies_to", ROUTINE_STATE_COMMANDS) if isinstance(field_selection, dict) else "unknown",
        },
        "slash_route_aliases": {
            "status": (slash_aliases or {}).get("status", "unknown") if isinstance(slash_aliases, dict) else "unknown",
            "aliases": (slash_aliases or {}).get("aliases", {}) if isinstance(slash_aliases, dict) else {},
            "cli_commands_added": False,
            "note": "Decision 43 aliases are slash-route aliases only, not Agentera CLI commands.",
        },
        "artifact_schemas": artifact_schemas,
        "doctor": {
            "command": "doctor",
            "removed_command": (doctor_contract or {}).get("removed_command", "unknown") if isinstance(doctor_contract, dict) else "unknown",
            "compatibility_alias": (doctor_contract or {}).get("compatibility_alias", "unknown") if isinstance(doctor_contract, dict) else "unknown",
            "self_check_categories": (doctor_contract or {}).get("owns", "unknown") if isinstance(doctor_contract, dict) else "unknown",
            "excludes": (doctor_contract or {}).get("excludes", "unknown") if isinstance(doctor_contract, dict) else "unknown",
            "adjacent_surfaces": (doctor_contract or {}).get("adjacent_surfaces", "unknown") if isinstance(doctor_contract, dict) else "unknown",
            "signal_kinds": DOCTOR_SIGNAL_KINDS,
        },
        "gaps": gaps,
    }


def cmd_describe(args: argparse.Namespace) -> int:
    _emit_structured(_build_describe_payload(), getattr(args, "format", "json"))
    return 0


def cmd_prime(_args: argparse.Namespace) -> int:
    print(PRIME_BLOB, end="")
    return 0


LINT_CHECKS = [
    ("verbosity", "Shorten the entry or split it into smaller concrete entries."),
    ("abstraction", "Add a concrete anchor such as a path, line number, metric, command, identifier, or quote."),
    ("filler", "Remove the named filler phrase category before writing the artifact."),
]


def _lint_input_text(args: argparse.Namespace) -> tuple[str, str]:
    if getattr(args, "text", None) is not None:
        return str(args.text), "text"
    if getattr(args, "file", None) is not None:
        path = Path(args.file)
        try:
            return path.read_text(encoding="utf-8"), str(path)
        except OSError as exc:
            raise ValueError(f"could not read lint file {path}: {exc}") from exc
    if sys.stdin.isatty():
        raise ValueError("lint requires --text, --file, or piped stdin")
    return sys.stdin.read(), "stdin"


def _lint_checks(text: str, artifact: str) -> list[dict[str, Any]]:
    self_audit = _load_self_audit_helper()
    raw_results = {
        "verbosity": self_audit.check_verbosity(text, artifact),
        "abstraction": self_audit.check_abstraction(text),
        "filler": self_audit.check_filler(text),
    }
    checks: list[dict[str, Any]] = []
    actions = dict(LINT_CHECKS)
    for name, _action in LINT_CHECKS:
        passed, detail = raw_results[name]
        checks.append({
            "name": name,
            "status": "pass" if passed else "fail",
            "detail": detail,
            "action": "" if passed else actions[name],
        })
    return checks


def _lint_payload(args: argparse.Namespace) -> dict[str, Any]:
    text, source = _lint_input_text(args)
    artifact = str(args.artifact)
    _validate_agent_string(artifact, "artifact")
    checks = _lint_checks(text, artifact)
    failures = [check for check in checks if check["status"] == "fail"]
    return {
        "command": "lint",
        "status": "fail" if failures else "pass",
        "artifact": artifact,
        "source": source,
        "strict": bool(getattr(args, "strict", False)),
        "checks": checks,
        "summary": {
            "failed": len(failures),
            "passed": len(checks) - len(failures),
            "advisory": not bool(getattr(args, "strict", False)),
        },
    }


def _emit_lint_text(payload: dict[str, Any]) -> None:
    failures = [check for check in payload["checks"] if check["status"] == "fail"]
    print(f"lint {payload['status']}: {payload['artifact']} ({payload['source']})")
    if not failures:
        print("all self-audit checks passed")
        return
    print(f"{len(failures)} issue(s); advisory by default, use --strict to fail on issues")
    for check in failures:
        print(f"- {check['name']}: {check['detail']}")
        print(f"  action: {check['action']}")


def cmd_lint(args: argparse.Namespace) -> int:
    payload = _lint_payload(args)
    if getattr(args, "format", "text") == "json":
        _emit_structured(payload, "json")
    else:
        _emit_lint_text(payload)
    return 1 if payload["status"] == "fail" and getattr(args, "strict", False) else 0


def _query_last_phase(args: argparse.Namespace, schemas: dict) -> int:
    output_format = getattr(args, "format", "text")
    info = schemas.get("progress")
    if not info:
        print(_missing_schema_error("progress"), file=sys.stderr)
        return 1
    data = _load_artifact(_artifact_path(info, "progress"))
    entries = _extract_entries(data)
    if not entries:
        if output_format != "text":
            _emit_structured(None, output_format)
        return 0
    last = _recent_cycles(entries, 1)[0]
    phase = last.get("phase", "")
    if output_format != "text":
        _emit_structured({"phase": phase}, output_format)
        return 0
    if phase:
        print(phase)
    return 0


def _compaction_operation_payload(op: Any) -> dict[str, Any]:
    status = op.status
    payload: dict[str, Any] = {
        "artifact": status.artifact,
        "path": status.path,
        "exists": status.exists,
        "classification": status.classification,
        "active_count": status.active_count,
        "archive_count": status.archive_count,
        "total_count": status.total_count,
        "over_limit_count": status.over_limit_count,
        "mode": op.mode,
        "action": op.action,
        "changed": op.changed,
        "message": op.message,
        "reason": status.reason,
    }
    if op.result is not None:
        payload["result"] = {
            "active_before": op.result.full_before,
            "archive_before": op.result.oneline_before,
            "active_after": op.result.full_after,
            "archive_after": op.result.oneline_after,
            "dropped": op.result.dropped,
            "changed": op.result.changed,
        }
    return payload


def _compaction_guidance(mode: str, operations: list[Any]) -> str:
    over = [op for op in operations if op.action in {"over_limit", "pending_fix"}]
    errors = [op for op in operations if op.action == "error"]
    check_command = "uv run scripts/agentera compact --mode check --format json"
    fix_command = "uv run scripts/agentera compact --mode fix --format json"
    if errors:
        return f"Inspect the reported errors, repair invalid artifacts, then rerun `{check_command}`."
    if mode == "check" and over:
        artifacts = ", ".join(op.status.artifact for op in over)
        return (
            f"Over-limit compactable artifacts: {artifacts}. "
            f"Safe check: `{check_command}`. "
            f"Safe fix: `{fix_command}`."
        )
    if mode == "fix" and over:
        return "Some artifacts remain over limit; inspect skipped or unsupported artifacts before manual remediation."
    return "No repair needed. Compactable artifacts are within uniform_10_40_50 limits."


def _compaction_summary(mode: str, operations: list[Any]) -> dict[str, Any]:
    counts: dict[str, int] = {}
    for op in operations:
        counts[op.action] = counts.get(op.action, 0) + 1
    over_limit = sum(1 for op in operations if op.action in {"over_limit", "pending_fix"})
    errors = sum(1 for op in operations if op.action == "error")
    changed = sum(1 for op in operations if op.changed)
    status = "fail" if errors or (mode == "check" and over_limit) else "pass"
    return {
        "status": status,
        "mode": mode,
        "artifact_count": len(operations),
        "over_limit_count": over_limit,
        "error_count": errors,
        "changed_count": changed,
        "action_counts": counts,
        "guidance": _compaction_guidance(mode, operations),
    }


def _compaction_exit_code(mode: str, operations: list[Any]) -> int:
    if any(op.action == "error" for op in operations):
        return 2
    if mode == "check" and any(op.action == "over_limit" for op in operations):
        return 1
    return 0


def cmd_compact(args: argparse.Namespace) -> int:
    mode = getattr(args, "mode", "check")
    project = getattr(args, "project", Path.cwd()).resolve()
    helper = _load_compaction_helper()
    operations = helper.run_compaction(project, mode=mode)
    payload = _compaction_payload("compact", project, mode, operations)
    _emit_compaction_payload(args, payload, mode)
    return _compaction_exit_code(mode, operations)


def _compaction_payload(command: str, project: Path, mode: str, operations: list[Any]) -> dict[str, Any]:
    summary = _compaction_summary(mode, operations)
    return {
        "command": command,
        "status": summary["status"],
        "project": str(project),
        "summary": summary,
        "operations": [_compaction_operation_payload(op) for op in operations],
    }


def _emit_compaction_payload(args: argparse.Namespace, payload: dict[str, Any], mode: str) -> None:
    summary = payload["summary"]
    project = payload["project"]
    if _output_format(args) == "json":
        _emit_structured(payload, "json")
    else:
        print(f"status={summary['status']} | mode={mode} | project={project}")
        print(
            "counts="
            f"artifacts:{summary['artifact_count']} "
            f"over_limit:{summary['over_limit_count']} "
            f"errors:{summary['error_count']} "
            f"changed:{summary['changed_count']}"
        )
        for item in payload["operations"]:
            print(
                f"- artifact={item['artifact']} | action={item['action']} | "
                f"classification={item['classification']} | path={item['path']} | "
                f"active={item['active_count']} | archive={item['archive_count']} | "
                f"total={item['total_count']} | over={item['over_limit_count']} | "
                f"message={item['message']}"
            )
        print(f"guidance={summary['guidance']}")


def cmd_gate(args: argparse.Namespace) -> int:
    project = getattr(args, "project", Path.cwd()).resolve()
    helper = _load_compaction_helper()
    operations = helper.run_compaction(project, mode="check")
    payload = _compaction_payload("gate", project, "check", operations)
    payload["gate"] = "compaction"
    _emit_compaction_payload(args, payload, "check")
    return _compaction_exit_code("check", operations)


def _query_decisions(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("decisions")
    if not info:
        print(_missing_schema_error("decisions"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "decisions")
    data = _load_artifact(path)
    entries = _extract_decision_entries(data)
    topic = getattr(args, "topic", None)
    if topic:
        entries = _filter_decisions_by_topic(entries, topic, info["fields"])
    if _output_format(args) != "text":
        entries = [_decision_context_entry(entry) for entry in entries]
        source = _source_metadata("decisions", path)
        filters = {"topic": topic}
        return _emit_state_structured(
            "decisions",
            _structured_state(
                "decisions",
                entries,
                source,
                filters=filters,
                source_contract=_decision_source_contract(source, entries, filters),
            ),
            args,
        )
    if not entries:
        return 0
    disp = _display_fields(info["fields"])
    for e in entries:
        parts = []
        for fn in disp:
            v = e.get(fn)
            if v is not None and v != "" and not isinstance(v, (list, dict)):
                parts.append(f"{fn}={v}")
        if parts:
            print(" | ".join(parts))
    return 0


def _query_health(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("health")
    if not info:
        print(_missing_schema_error("health"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "health")
    data = _load_artifact(path)
    entries = _extract_entries(data)
    dimension = getattr(args, "dimension", None)
    latest_entries = entries[:1]
    if dimension and latest_entries:
        latest = latest_entries[0]
        dim_lower = dimension.lower()
        matched = False
        grades = latest.get("grades", {})
        if isinstance(grades, dict):
            matched = any(dim_lower in str(gk).lower() for gk in grades)
        details = latest.get("dimensions_detail", [])
        if isinstance(details, list):
            matched = matched or any(dim_lower in str(d.get("name", "")).lower() for d in details if isinstance(d, dict))
        if not matched:
            latest_entries = []
    if _output_format(args) != "text":
        return _emit_state_structured(
            "health",
            _structured_state(
                "health",
                latest_entries,
                _source_metadata("health", path),
                filters={"dimension": dimension},
                summary={"latest_only": True},
            ),
            args,
        )
    if not entries:
        return 0
    latest = entries[0]
    if dimension:
        dim_lower = dimension.lower()
        grades = latest.get("grades", {})
        matched = False
        for gk, gv in grades.items():
            if dim_lower in gk.lower():
                print(f"{gk}: {gv}")
                matched = True
        details = latest.get("dimensions_detail", [])
        for d in details:
            dn = d.get("name", "")
            if dim_lower in dn.lower():
                summary = d.get("summary", "")
                if summary:
                    print(f"  {summary}")
                for f in d.get("findings", []):
                    sev = f.get("severity", "")
                    heading = f.get("heading", "")
                    print(f"  [{sev}] {heading}")
                matched = True
        if not matched:
            return 0
    else:
        num = latest.get("number", "?")
        traj = latest.get("trajectory", "")
        print(f"Audit {num}: {traj}")
        grades = latest.get("grades", {})
        for gk, gv in grades.items():
            print(f"  {gk}: {gv}")
    return 0


def _query_open_todos(args: argparse.Namespace, schemas: dict) -> int:
    return _query_todo(args, schemas, open_only=True)


def _query_todo(
    args: argparse.Namespace,
    schemas: dict,
    *,
    open_only: bool = False,
) -> int:
    info = schemas.get("todo", {"path": "TODO.md", "fields": {}})
    todo_path = _artifact_path(info, "todo")
    severity = getattr(args, "severity", None)
    status = getattr(args, "status", None)
    if not todo_path.exists():
        if _output_format(args) != "text":
            return _emit_state_structured(
                "todo",
                _structured_state(
                    "todo",
                    [],
                    _source_metadata("todo", todo_path),
                    filters={"severity": severity, "status": status},
                ),
                args,
            )
        return 0
    data = _load_artifact(todo_path)
    entries = _extract_entries(data)
    if entries:
        if severity:
            entries = _filter_by_field_value(entries, "severity", severity)
        if status:
            entries = _filter_by_field_value(entries, "status", status)
        if open_only:
            entries = [
                entry for entry in entries
                if str(entry.get("status", "open")).lower() not in {"done", "closed", "resolved"}
            ]
        if _output_format(args) != "text":
            return _emit_state_structured(
                "todo",
                _structured_state(
                    "todo",
                    entries,
                    _source_metadata("todo", todo_path),
                    filters={"severity": severity, "status": status, "open_only": open_only or None},
                ),
                args,
            )
        _print_status_counts("TODO status", _status_counts(entries))
        for entry in entries:
            line = _format_entry(entry, ["severity", "status", "description", "title"])
            if line:
                print(line)
        return 0

    text = todo_path.read_text(encoding="utf-8")
    sev_map = {
        "critical": "\u21f6",
        "degraded": "\u21c9",
        "warning": "\u21c9",
        "normal": "\u2192",
        "info": "\u21e2",
        "annoying": "\u21e2",
    }
    marker = sev_map.get(severity.lower(), severity) if severity else None
    current_section = None
    found = False
    markdown_entries = []
    for line in text.splitlines():
        s = line.strip()
        if s.startswith("## "):
            section = s[3:].strip()
            if section == "Resolved":
                current_section = None
                continue
            current_section = section
            continue
        if current_section is None:
            continue
        if not s.startswith("- [ ]"):
            continue
        if marker and marker not in current_section:
            continue
        found = True
        item = s[5:].strip()
        if status and status.lower() not in {"open", "todo"}:
            continue
        markdown_entries.append({
            "severity": _normalize_severity(current_section),
            "status": "open",
            "description": item,
            "section": current_section,
        })
        if _output_format(args) == "text":
            print(f"[{current_section}] {item}")
    if _output_format(args) != "text":
        return _emit_state_structured(
            "todo",
            _structured_state(
                "todo",
                markdown_entries,
                _source_metadata("todo", todo_path),
                filters={"severity": severity, "status": status, "open_only": open_only or None},
            ),
            args,
        )
    return 0


def _query_plan(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("plan")
    if not info:
        print(_missing_schema_error("plan"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "plan")
    data = _load_artifact(path)
    if not isinstance(data, dict):
        if _output_format(args) != "text":
            source = _source_metadata("plan", path)
            summary = {"absence_reason": "No plan artifact is available from agentera plan."}
            return _emit_state_structured(
                "plan",
                _structured_state(
                    "plan",
                    [],
                    source,
                    filters={"status": getattr(args, "status", None)},
                    summary=summary,
                    source_contract=_plan_source_contract(source, summary),
                ),
                args,
            )
        return 0
    legacy_entries = _as_list(data.get("entries"))
    if legacy_entries:
        status_filter = getattr(args, "status", None)
        if status_filter:
            legacy_entries = _filter_by_field_value(legacy_entries, "status", status_filter)
        source = _source_metadata("plan", path)
        summary = {"legacy_entries": True}
        if _output_format(args) != "text":
            return _emit_state_structured(
                "plan",
                _structured_state(
                    "plan",
                    legacy_entries,
                    source,
                    filters={"status": status_filter},
                    summary=summary,
                    source_contract=_plan_source_contract(source, summary),
                ),
                args,
            )
        for entry in legacy_entries:
            line = _format_entry(entry, ["status", "title", "name"])
            if line:
                print(line)
        return 0
    header = data.get("header") if isinstance(data.get("header"), dict) else {}
    summary = _plan_artifact_summary(data, header)
    title = summary.get("title", "")
    status = summary.get("status", "")
    created = summary.get("created", "")
    tasks = _as_list(data.get("tasks"))
    status_filter = getattr(args, "status", None)
    if status_filter:
        tasks = _filter_by_field_value(tasks, "status", status_filter)
    source = _source_metadata("plan", path)
    if _output_format(args) != "text":
        return _emit_state_structured(
            "plan",
            _structured_state(
                "plan",
                tasks,
                source,
                filters={"status": status_filter},
                summary=summary,
                source_contract=_plan_source_contract(source, summary),
            ),
            args,
        )
    print(f"Plan: status={status or 'unknown'} | title={_truncate(title)} | created={created or '-'}")
    for key in ("what", "why"):
        value = data.get(key)
        if value:
            print(f"{key}: {_truncate(value)}")
    _print_status_counts("Task status", _status_counts(tasks))
    for task in tasks[:10]:
        line = _format_entry(task, ["number", "status", "name", "title"])
        if line:
            print(f"Task: {line}")
    return 0


def _query_progress(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("progress")
    if not info:
        print(_missing_schema_error("progress"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "progress")
    data = _load_artifact(path)
    entries = _extract_entries(data)
    topic = getattr(args, "topic", None)
    if topic:
        entries = _filter_by_topic(entries, topic, info["fields"])
    status_filter = getattr(args, "status", None)
    if status_filter:
        entries = _filter_by_field_value(entries, "type", status_filter)
    limit = getattr(args, "limit", 5) or 5
    entries = _recent_cycles(entries, limit)
    if _output_format(args) != "text":
        return _emit_state_structured(
            "progress",
            _structured_state(
                "progress",
                entries,
                _source_metadata("progress", path),
                filters={"topic": topic, "status": status_filter, "limit": limit},
            ),
            args,
        )
    if not entries:
        return 0
    for entry in entries:
        print(_format_entry(entry, ["number", "timestamp", "type", "phase", "commit"]))
        for key in ("what", "verified", "next"):
            value = entry.get(key)
            if value:
                print(f"  {key}: {_truncate(value)}")
    return 0


def _query_docs(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("docs")
    if not info:
        print(_missing_schema_error("docs"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "docs")
    data = _load_artifact(path)
    if not isinstance(data, dict):
        if _output_format(args) != "text":
            return _emit_state_structured(
                "docs",
                _structured_state("docs", [], _source_metadata("docs", path), filters={"topic": getattr(args, "topic", None), "status": getattr(args, "status", None)}),
                args,
            )
        return 0
    legacy_entries = _as_list(data.get("entries"))
    if legacy_entries:
        status_filter = getattr(args, "status", None)
        if status_filter:
            legacy_entries = _filter_by_field_value(legacy_entries, "status", status_filter)
        if _output_format(args) != "text":
            return _emit_state_structured(
                "docs",
                _structured_state("docs", legacy_entries, _source_metadata("docs", path), filters={"status": status_filter}),
                args,
            )
        for entry in legacy_entries:
            line = _format_entry(entry, ["last_audit", "document", "path", "status"])
            if line:
                print(line)
        return 0
    mapping = _as_list(data.get("mapping"))
    index = _as_list(data.get("index"))
    coverage = data.get("coverage") if isinstance(data.get("coverage"), dict) else {}
    conventions = data.get("conventions") if isinstance(data.get("conventions"), dict) else {}
    topic = getattr(args, "topic", None)
    if topic:
        t = topic.lower()
        index = [
            entry for entry in index
            if t in str(entry.get("document", "")).lower()
            or t in str(entry.get("path", "")).lower()
            or t in str(entry.get("status", "")).lower()
        ]
    status_filter = getattr(args, "status", None)
    if status_filter:
        index = _filter_by_field_value(index, "status", status_filter)
    if _output_format(args) != "text":
        return _emit_state_structured(
            "docs",
            _structured_state(
                "docs",
                index,
                _source_metadata("docs", path),
                filters={"topic": topic, "status": status_filter},
                summary={
                    "last_audit": data.get("last_audit"),
                    "conventions": conventions,
                    "mapping": mapping,
                    "mapping_entries": len(mapping),
                    "coverage": coverage,
                    "source_contract": {
                        "capability_startup_complete": not STARTUP_COMPLETENESS_MISSING_STATE,
                        "raw_artifact_reads_required": False,
                    },
                },
            ),
            args,
        )
    print(f"Docs: last_audit={data.get('last_audit', '-')}")
    print(f"Mapping: entries={len(mapping)}")
    if coverage:
        print(
            "Coverage: "
            + " | ".join(f"{key}={_truncate(value)}" for key, value in coverage.items())
        )
    _print_status_counts("Docs status", _status_counts(index))
    for entry in index[:10]:
        line = _format_entry(entry, ["document", "path", "last_updated", "status"])
        if line:
            print(line)
    return 0


def _query_session(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("session")
    if not info:
        print(_missing_schema_error("session"), file=sys.stderr)
        return 1
    data = _load_artifact(_artifact_path(info, "session"))
    entries = _extract_entries(data)
    if not entries:
        return 0
    limit = getattr(args, "limit", 5) or 5
    for entry in entries[-limit:]:
        print(_format_entry(entry, ["timestamp", "summary"]))
        artifacts = entry.get("artifacts")
        if artifacts:
            print(f"  artifacts={_truncate(artifacts)}")
    return 0


def _query_design(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("design")
    if not info:
        print(_missing_schema_error("design"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "design")
    data = _load_artifact(path)
    entries = _extract_entries(data)
    if entries:
        topic = getattr(args, "topic", None)
        if topic:
            entries = _filter_by_topic(entries, topic, info["fields"])
        for entry in entries:
            line = _format_entry(entry, ["category", "name", "value"])
            if line:
                print(line)
        return 0
    if not path.exists():
        return 0
    text = path.read_text(encoding="utf-8")
    markers = []
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("<!-- design:") and stripped.endswith("-->"):
            markers.append(stripped.removeprefix("<!-- design:").removesuffix("-->").strip())
    print(f"Design: sections={len(markers)}")
    for marker in markers[:20]:
        print(f"category={marker}")
    return 0


def _query_objective(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("objective")
    if not info:
        print(_missing_schema_error("objective"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "objective")
    data = _load_artifact(path)
    if not isinstance(data, dict):
        if _output_format(args) != "text":
            return _emit_state_structured(
                "objective",
                _structured_state("objective", [], _source_metadata("objective", path), filters={"status": getattr(args, "status", None)}),
                args,
            )
        return 0
    legacy_entries = _as_list(data.get("entries"))
    if legacy_entries:
        status_filter = getattr(args, "status", None)
        if status_filter:
            legacy_entries = _filter_by_field_value(legacy_entries, "status", status_filter)
        if _output_format(args) != "text":
            return _emit_state_structured(
                "objective",
                _structured_state("objective", legacy_entries, _source_metadata("objective", path), filters={"status": status_filter}),
                args,
            )
        for entry in legacy_entries:
            line = _format_entry(entry, ["title", "status", "target", "reason"])
            if line:
                print(line)
        return 0
    header = data.get("header") if isinstance(data.get("header"), dict) else {}
    objective = data.get("objective") if isinstance(data.get("objective"), dict) else data
    title = _first_present(header, ["title"], objective.get("title", ""))
    status = _first_present(header, ["status"], objective.get("status", ""))
    closure = data.get("closure") if isinstance(data.get("closure"), dict) else {}
    if _output_format(args) != "text":
        return _emit_state_structured(
            "objective",
            _structured_state(
                "objective",
                [objective] if objective else [],
                _source_metadata("objective", path),
                filters={"status": getattr(args, "status", None)},
                summary={"title": title, "status": status, "header": header, "closure": closure},
            ),
            args,
        )
    print(f"Objective: title={_truncate(title)} | status={status or 'unknown'}")
    for key in ("description", "target", "measurement", "direction", "unit"):
        value = objective.get(key) or data.get(key)
        if value:
            print(f"{key}: {_truncate(value)}")
    if closure:
        print(_format_entry(closure, ["final_value", "target", "reason"]))
    return 0


def _query_experiments(args: argparse.Namespace, schemas: dict) -> int:
    info = schemas.get("experiments")
    if not info:
        print(_missing_schema_error("experiments"), file=sys.stderr)
        return 1
    path = _artifact_path(info, "experiments")
    data = _load_artifact(path)
    if not isinstance(data, dict):
        if _output_format(args) != "text":
            return _emit_state_structured(
                "experiments",
                _structured_state("experiments", [], _source_metadata("experiments", path), filters={"topic": getattr(args, "topic", None), "status": getattr(args, "status", None), "limit": getattr(args, "limit", 5)}),
                args,
            )
        return 0
    entries = _as_list(data.get("experiments"))
    status_filter = getattr(args, "status", None)
    if status_filter:
        entries = _filter_by_field_value(entries, "status", status_filter)
    topic = getattr(args, "topic", None)
    if topic:
        entries = _filter_by_topic(entries, topic, info["fields"])
    limit = getattr(args, "limit", 5) or 5
    entries = entries[-limit:]
    closure = data.get("closure") if isinstance(data.get("closure"), dict) else {}
    if _output_format(args) != "text":
        return _emit_state_structured(
            "experiments",
            _structured_state(
                "experiments",
                entries,
                _source_metadata("experiments", path),
                filters={"topic": topic, "status": status_filter, "limit": limit},
                summary={"closure": closure},
            ),
            args,
        )
    _print_status_counts("Experiment status", _status_counts(entries))
    for entry in entries:
        print(_format_entry(entry, ["number", "date", "label", "status"]))
        metric = entry.get("metric")
        if isinstance(metric, dict):
            metric_line = _format_entry(metric, ["primary_value", "delta_vs_baseline"])
            if metric_line:
                print(f"  metric: {metric_line}")
        for key in ("conclusion", "next"):
            value = entry.get(key)
            if value:
                print(f"  {key}: {_truncate(value)}")
    if closure:
        print("Closure: " + _format_entry(closure, ["final_value", "target", "reason"]))
    return 0


DONE_STATUSES = {"complete", "completed", "closed", "done", "resolved", "retired"}
BLOCKED_STATUSES = {"blocked", "stuck"}

_PROFILERA_STALE_DAYS_ENV = "AGENTERA_PROFILERA_MAX_AGE_DAYS"
_DEFAULT_PROFILERA_STALE_DAYS = 7
TODO_SEVERITY_ORDER = {
    "critical": 0,
    "degraded": 1,
    "warning": 1,
    "normal": 2,
    "info": 3,
    "annoying": 3,
}
TODO_SECTION_SEVERITIES = {
    "critical": "critical",
    "degraded": "degraded",
    "warning": "warning",
    "normal": "normal",
    "info": "info",
    "annoying": "annoying",
}


def _profilera_stale_threshold_days() -> int:
    raw_value = os.environ.get(_PROFILERA_STALE_DAYS_ENV, str(_DEFAULT_PROFILERA_STALE_DAYS))
    try:
        stale_days = int(raw_value)
    except ValueError:
        return _DEFAULT_PROFILERA_STALE_DAYS
    return stale_days if stale_days >= 0 else _DEFAULT_PROFILERA_STALE_DAYS


def _check_profilera_staleness(profile_path: Path) -> tuple[bool, int, int] | None:
    if not profile_path.exists():
        return None
    try:
        text = profile_path.read_text(encoding="utf-8")
    except Exception:
        return None
    m = re.search(r"<!-- Generated:\s*(\d{4}-\d{2}-\d{2})", text)
    if not m:
        return None
    try:
        generated = date.fromisoformat(m.group(1))
    except ValueError:
        return None
    stale_days = _profilera_stale_threshold_days()
    days_since = (date.today() - generated).days
    return days_since >= stale_days, days_since, stale_days


def _load_named_artifact(schemas: dict, name: str) -> Any:
    info = schemas.get(name)
    if not info:
        return None
    return _load_artifact(_artifact_path(info, name))


def _entry_status(entry: dict, default: str = "open") -> str:
    return str(entry.get("status", default) or default).lower()


def _is_open_entry(entry: dict) -> bool:
    return _entry_status(entry) not in DONE_STATUSES


def _normalize_severity(value: Any, default: str = "normal") -> str:
    text = str(value or default).lower()
    for key in TODO_SEVERITY_ORDER:
        if key in text:
            return key
    return default


def _load_todo_items(schemas: dict) -> list[dict[str, str]]:
    info = schemas.get("todo", {"path": "TODO.md", "fields": {}})
    todo_path = _artifact_path(info, "todo")
    if not todo_path.exists():
        return []
    data = _load_artifact(todo_path)
    entries = _extract_entries(data)
    if entries:
        items = []
        for entry in entries:
            if not _is_open_entry(entry):
                continue
            text = _first_present(entry, ["description", "title", "name"], "")
            if not text:
                continue
            items.append({
                "severity": _normalize_severity(entry.get("severity")),
                "status": _entry_status(entry),
                "text": str(text),
            })
        return items

    items = []
    current_severity = ""
    text = todo_path.read_text(encoding="utf-8")
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("## "):
            heading = stripped[3:].strip().lower()
            if "resolved" in heading:
                current_severity = ""
            else:
                current_severity = next(
                    (sev for marker, sev in TODO_SECTION_SEVERITIES.items() if marker in heading),
                    "normal",
                )
            continue
        if current_severity and stripped.startswith("- [ ]"):
            items.append({
                "severity": current_severity,
                "status": "open",
                "text": stripped[5:].strip(),
            })
    return items


def _issue_counts(todo_items: list[dict[str, str]]) -> dict[str, int]:
    counts = {"critical": 0, "degraded": 0, "normal": 0, "annoying": 0}
    for item in todo_items:
        severity = item["severity"]
        if severity == "critical":
            counts["critical"] += 1
        elif severity in {"degraded", "warning"}:
            counts["degraded"] += 1
        elif severity in {"info", "annoying"}:
            counts["annoying"] += 1
        else:
            counts["normal"] += 1
    return counts


def _plan_summary(schemas: dict) -> dict[str, Any]:
    data = _load_named_artifact(schemas, "plan")
    if not isinstance(data, dict):
        return {
            "exists": False,
            "active": False,
            "tasks": [],
            "status": "absent",
            "title": "",
            "absence_reason": "No active plan artifact is available from agentera plan.",
        }
    legacy_entries = _as_list(data.get("entries"))
    if legacy_entries:
        tasks = legacy_entries
        status = _entry_status(tasks[0], "")
        title = _first_present(tasks[0], ["title", "name"], "")
    else:
        header = data.get("header") if isinstance(data.get("header"), dict) else {}
        tasks = _as_list(data.get("tasks"))
        status = str(_first_present(header, ["status"], data.get("status", "")) or "")
        title = str(_first_present(header, ["title"], data.get("title", "")) or "")
    complete = sum(1 for task in tasks if _entry_status(task, "") in DONE_STATUSES)
    total = len(tasks)
    complete_plan = status.lower() in DONE_STATUSES and complete == total
    first_pending = None
    if not complete_plan:
        for task in tasks:
            task_status = _entry_status(task, "pending")
            if task_status in DONE_STATUSES or task_status in BLOCKED_STATUSES:
                continue
            first_pending = task
            break
    return {
        "exists": True,
        "status": status,
        "title": title,
        "tasks": tasks,
        "complete": complete,
        "total": total,
        "active": not complete_plan,
        "complete_plan": complete_plan,
        "first_pending": first_pending,
    }


def _docs_summary(schemas: dict) -> dict[str, Any]:
    data = _load_named_artifact(schemas, "docs")
    if not isinstance(data, dict):
        return {
            "exists": False,
            "status": "absent",
            "absence_reason": "No docs mapping artifact is available from agentera docs.",
        }
    mapping = _as_list(data.get("mapping"))
    index = _as_list(data.get("index"))
    coverage = data.get("coverage") if isinstance(data.get("coverage"), dict) else {}
    conventions = data.get("conventions") if isinstance(data.get("conventions"), dict) else {}
    return {
        "exists": True,
        "status": "available",
        "last_audit": data.get("last_audit"),
        "conventions": conventions,
        "mapping": mapping,
        "mapping_entries": len(mapping),
        "coverage": coverage,
        "source_contract": {
            "capability_startup_complete": not STARTUP_COMPLETENESS_MISSING_STATE,
            "raw_artifact_reads_required": False,
            "state_families": [
                "plan task details, dependencies, acceptance criteria, and evidence summaries",
                "docs artifact mapping and source-contract completeness metadata",
                "latest progress verification metadata needed for Orkestrera evaluation",
                "Dokumentera closeout context metadata for docs/TODO/changelog/progress synchronization",
            ],
        },
        "indexed_documents": len(index),
    }


def _progress_summary(schemas: dict) -> dict[str, Any]:
    data = _load_named_artifact(schemas, "progress")
    entries = _extract_entries(data)
    if not entries:
        return {
            "exists": False,
            "status": "absent",
            "absence_reason": "No progress cycles are available from agentera progress.",
        }
    latest = _recent_cycles(entries, 1)[0]
    return {
        "exists": True,
        "status": "available",
        "latest": latest,
        "latest_verification": latest.get("verified"),
        "cycle_count": len(entries),
    }


def _health_summary(schemas: dict) -> dict[str, Any]:
    data = _load_named_artifact(schemas, "health")
    entries = _extract_entries(data)
    if not entries:
        return {"exists": False}
    latest = entries[0]
    grades = latest.get("grades") if isinstance(latest.get("grades"), dict) else {}
    grade_rank = {"A": 0, "B": 1, "C": 2, "D": 3, "F": 4}
    worst = None
    for name, grade in grades.items():
        grade_text = str(grade).upper()
        rank = grade_rank.get(grade_text[:1], -1)
        if worst is None or rank > worst[2]:
            worst = (name, grade, rank)
    trajectory = str(latest.get("trajectory", "") or "")
    return {
        "exists": True,
        "number": latest.get("number", "?"),
        "timestamp": latest.get("timestamp"),
        "trajectory": trajectory,
        "grade": worst[1] if worst else "",
        "worst": worst,
        "degrading": trajectory.lower() in {"degrading", "declining", "worse"}
        or (worst is not None and worst[2] >= grade_rank["D"]),
    }


def _objective_status(data: dict) -> str:
    header = data.get("header") if isinstance(data.get("header"), dict) else {}
    objective = data.get("objective") if isinstance(data.get("objective"), dict) else {}
    return str(
        _first_present(header, ["status"], data.get("status") or objective.get("status") or "")
        or ""
    ).lower()


def _active_objective_summary() -> dict[str, Any]:
    root = Path.cwd() / ".agentera" / "optimera"
    if not root.is_dir():
        return {"exists": False}
    candidates = []
    closed_count = 0
    for candidate in root.iterdir():
        if not candidate.is_dir():
            continue
        objective_path = candidate / "objective.yaml"
        if not objective_path.exists():
            continue
        data = _load_artifact(objective_path)
        if not isinstance(data, dict):
            continue
        status = _objective_status(data)
        if status in DONE_STATUSES:
            closed_count += 1
            continue
        candidates.append((candidate, data, status))
    if not candidates:
        return {"exists": closed_count > 0, "active": False, "closed_count": closed_count}
    candidates.sort(key=lambda item: item[0].stat().st_mtime, reverse=True)
    path, data, status = candidates[0]
    header = data.get("header") if isinstance(data.get("header"), dict) else {}
    objective = data.get("objective") if isinstance(data.get("objective"), dict) else data
    title = _first_present(header, ["title"], objective.get("title", path.name))
    metric = _first_present(objective, ["measurement", "metric", "direction", "target"], title)
    target = _first_present(objective, ["target"], "")
    return {
        "exists": True,
        "active": True,
        "name": path.name,
        "title": str(title),
        "status": status or "active",
        "metric": str(metric),
        "target": str(target),
    }


def _state_presence(plan: dict[str, Any], docs: dict[str, Any], progress: dict[str, Any], health: dict[str, Any], objective: dict[str, Any]) -> dict[str, Any]:
    active = {
        "plan": bool(plan.get("active")),
        "objective": bool(objective.get("active")),
    }
    available = {
        "plan": bool(plan.get("exists")),
        "docs": bool(docs.get("exists")),
        "progress": bool(progress.get("exists")),
        "health": bool(health.get("exists")),
        "objective": bool(objective.get("exists")),
    }
    absence = {
        name: summary.get("absence_reason")
        for name, summary in (("plan", plan), ("docs", docs), ("progress", progress))
        if not summary.get("exists") and summary.get("absence_reason")
    }
    return {
        "active": active,
        "available": available,
        "any_active": any(active.values()),
        "absence_explained": bool(absence) or any(active.values()),
        "absence": absence,
    }


def _decision_follow_up(schemas: dict) -> dict[str, Any] | None:
    data = _load_named_artifact(schemas, "decisions")
    for entry in _extract_entries(data):
        status = _entry_status(entry, "")
        text = " ".join(
            str(entry.get(key, ""))
            for key in ("status", "choice", "reasoning", "follow_up")
        )
        if status in {"pending", "open", "unresolved"} or "follow" in text.lower():
            number = entry.get("number", "?")
            title = _first_present(entry, ["question", "choice"], "decision follow-up")
            return {"object": f"DECISION {number} follow-up", "title": title}
    return None


def _format_next_action(action: dict[str, str] | None) -> str:
    if not action:
        return "object=VISION refresh | capability=visionera | reason=no executable follow-up"
    return (
        f"object={_truncate(action['object'])} | "
        f"capability={action['capability']} | reason={action['reason']}"
    )


def _select_hej_next_action(
    plan: dict[str, Any],
    health: dict[str, Any],
    objective: dict[str, Any],
    todo_items: list[dict[str, str]],
    decision: dict[str, Any] | None,
    saved_context: bool,
) -> dict[str, str]:
    pending = plan.get("first_pending")
    if isinstance(pending, dict):
        number = pending.get("number", "?")
        title = _first_present(pending, ["name", "title"], "pending task")
        return {
            "object": f"PLAN Task {number}: {title}",
            "capability": "orkestrera",
            "reason": "first pending plan task",
        }
    if health.get("degrading"):
        worst = health.get("worst")
        target = f"{worst[0]}:{worst[1]}" if worst else "degrading health"
        return {
            "object": f"HEALTH: {target}",
            "capability": "inspektera",
            "reason": "critical or degrading health",
        }
    if objective.get("active"):
        return {
            "object": f"OBJECTIVE: {objective.get('metric') or objective.get('title')}",
            "capability": "optimera",
            "reason": "active non-closed objective",
        }
    if todo_items:
        item = sorted(
            todo_items,
            key=lambda entry: TODO_SEVERITY_ORDER.get(entry["severity"], 2),
        )[0]
        return {
            "object": f"TODO: {item['text']}",
            "capability": "realisera",
            "reason": "highest-priority open TODO",
        }
    if decision:
        return {
            "object": str(decision["object"]),
            "capability": "resonera",
            "reason": "unresolved decision follow-up",
        }
    vision_exists = (Path.cwd() / ".agentera" / "vision.yaml").exists()
    if plan.get("exists") and not plan.get("complete_plan"):
        return {
            "object": "VISION refresh",
            "capability": "planera",
            "reason": "no executable follow-up",
        }
    if vision_exists:
        return {
            "object": "VISION refresh",
            "capability": "planera",
            "reason": "no executable follow-up",
        }
    if saved_context:
        return {
            "object": "Direction clarification",
            "capability": "resonera",
            "reason": "saved context without vision",
        }
    return {
        "object": "VISION refresh",
        "capability": "visionera",
        "reason": "fresh project direction",
    }


def cmd_hej(_args: argparse.Namespace) -> int:
    schemas_dir = _discover_schemas_dir()
    schemas = _load_schemas(schemas_dir)
    bundle = _hej_bundle_status(_args)
    saved_context = any((Path.cwd() / ".agentera").glob("*.yaml"))
    mode = "returning" if saved_context else "fresh"
    profile = _registry_artifact_path("profile", schemas_dir)
    profile_status = "loaded" if profile.exists() else "not found"
    profile_staleness = _check_profilera_staleness(profile) if profile.exists() else None
    profile_dict: dict[str, Any] = {"status": profile_status, "path": str(profile)}
    if profile_status == "not found":
        profile_dict["suggested_action"] = "Run profilera to generate PROFILE.md"
    if profile_staleness is not None:
        is_stale, days_since, stale_days = profile_staleness
        profile_dict["days_since_generated"] = days_since
        profile_dict["stale"] = is_stale
        profile_dict["stale_threshold_days"] = stale_days
        if is_stale:
            profile_dict["suggested_action"] = "Run profilera to refresh PROFILE.md"
    v1_artifacts = _detect_v1_artifacts()
    v1_migration = _v1_migration_summary(v1_artifacts)
    plan = _plan_summary(schemas)
    docs = _docs_summary(schemas)
    progress = _progress_summary(schemas)
    health = _health_summary(schemas)
    objective = _active_objective_summary()
    state_presence = _state_presence(plan, docs, progress, health, objective)
    todo_items = _load_todo_items(schemas)
    counts = _issue_counts(todo_items)
    decision = _decision_follow_up(schemas)
    next_action = _select_hej_next_action(plan, health, objective, todo_items, decision, saved_context)
    attention = []
    if bundle["status"] != "fresh":
        attention.append(_app_status_attention(bundle))
    if v1_migration["detected"]:
        command = v1_migration["dry_run_command"]
        attention.append(
            f"degraded: v1 artifacts detected; preview `{command}`; files={', '.join(v1_artifacts)}"
        )
    if profile_status == "not found":
        attention.append(f"degraded: PROFILE.md not found at {profile}; suggest running profilera to generate PROFILE.md")
    elif profile_staleness is not None and profile_staleness[0]:
        _, days_since, stale_days = profile_staleness
        attention.append(
            f"normal: profilera profile stale ({days_since} days since generated; "
            f"threshold={stale_days}); suggest running profilera to refresh PROFILE.md"
        )
    if health.get("degrading"):
        worst = health.get("worst")
        attention.append(
            f"critical: health needs attention ({worst[0]}:{worst[1]})"
            if worst
            else "critical: health is degrading"
        )
    pending = plan.get("first_pending")
    if isinstance(pending, dict):
        title = _first_present(pending, ["name", "title"], "pending task")
        attention.append(f"normal: PLAN Task {pending.get('number', '?')}: {title}")
    elif todo_items:
        first_todo = sorted(
            todo_items,
            key=lambda entry: TODO_SEVERITY_ORDER.get(entry["severity"], 2),
        )[0]
        attention.append(f"{first_todo['severity']}: TODO: {first_todo['text']}")
    capability_name = getattr(_args, "capability_context", None)
    orchestration_context = _orchestration_context(
        capability_name,
        plan,
        progress,
        health,
        todo_items,
        docs,
        profile_dict,
        next_action,
    )
    closeout_context = _dokumentera_closeout_context(
        capability_name,
        schemas,
        plan,
        progress,
        todo_items,
        docs,
        profile_dict,
        bundle,
    )
    evidence_context = _inspektera_evidence_context(
        capability_name,
        schemas,
        plan,
        progress,
        health,
        todo_items,
        docs,
        profile_dict,
        bundle,
    )
    if _output_format(_args) != "text":
        bundle_public = public_doctor_status(bundle)
        app_home = {
            "status": bundle["status"],
            "home": bundle["appHome"],
            "source": bundle["appHomeSource"],
            "managed_app_root": bundle["managedAppRoot"],
            "user_data_root": bundle["userDataRoot"],
        }
        return _emit_state_structured(
            "hej",
            {
                "command": "hej",
                "status": "ok",
                "app_home": app_home,
                "bundle": bundle_public,
                "mode": mode,
                "profile": profile_dict,
                "v1_migration": v1_migration,
                "health": health,
                "issues": counts,
                "plan": plan,
                "docs": docs,
                "progress": progress,
                "objective": objective,
                "state_presence": state_presence,
                "attention": attention[:6],
                "next_action": next_action,
                "orchestration_context": orchestration_context,
                "closeout_context": closeout_context,
                "evidence_context": evidence_context,
                "source": {
                    "schemas_dir": str(schemas_dir),
                    "project": str(Path.cwd()),
                    "artifacts_present": mode == "returning",
                },
                "source_contract": {
                    "fields": STARTUP_COMPLETENESS_AVAILABLE_STATE,
                    "render": "caller-owned README-style hej dashboard",
                    "access": "single installed CLI call; app/v1/profile safety included; no preflight glob/read/import/doctor calls during normal hej",
                    "empty_state": "fresh mode with missing artifact summaries and zero issue counts",
                    "capability_startup": _startup_completeness_contract(),
                    "capability_context": _capability_context(capability_name),
                },
            },
            _args,
        )

    print("agentera hej")
    print(
        f"app_home: status={bundle['status']} | home={bundle['appHome']} | "
        f"source={bundle['appHomeSource']} | managed_app={bundle['managedAppRoot']} | user_data={bundle['userDataRoot']} | expected={bundle['expectedVersion']} | "
        f"expected_source={bundle.get('expectedVersionSource', '-')} | current={bundle.get('markerVersion') or '-'}"
    )
    print(f"mode: {mode}")
    print(f"profile: {profile_status} | path={profile}")
    if health.get("exists"):
        worst = health.get("worst")
        worst_text = f"{worst[0]}:{worst[1]}" if worst else "none"
        print(
            f"health: audit={health.get('number')} | "
            f"grade={health.get('grade') or 'unknown'} | "
            f"trajectory={health.get('trajectory') or 'unknown'} | worst={worst_text}"
        )
    print(
        "issues: "
        f"critical={counts['critical']} | degraded={counts['degraded']} | "
        f"normal={counts['normal']} | annoying={counts['annoying']}"
    )
    if not state_presence["any_active"]:
        missing = ", ".join(sorted(state_presence["absence"])) or "none"
        print(f"state: no active plan or objective | missing={missing}")
    if plan.get("exists") and not plan.get("complete_plan"):
        print(
            f"plan: status={plan.get('status') or 'unknown'} | "
            f"progress={plan.get('complete', 0)}/{plan.get('total', 0)}"
        )
    if objective.get("active"):
        target = f" | target={objective['target']}" if objective.get("target") else ""
        print(
            f"objective: active | name={objective['name']} | "
            f"metric={objective['metric']}{target}"
        )
    elif objective.get("exists"):
        print(f"objective: none active | closed={objective.get('closed_count', 0)}")
    else:
        print("objective: none active")

    if attention:
        print("attention:")
        for item in attention[:6]:
            print(f"- {item}")
    print("next_action:")
    print(f"- {_format_next_action(next_action)}")
    print("source_contract:")
    print("- fields=app_home,mode,profile,v1_migration,health,issues,plan,docs,progress,objective,state_presence,attention,next_action,orchestration_context,closeout_context,evidence_context")
    print("- render=caller-owned README-style hej dashboard")
    print("- access=single installed CLI call; app/v1/profile safety included; no preflight glob/read/import/doctor calls")
    startup_contract = _startup_completeness_contract()
    print(f"- capability_startup_complete={str(startup_contract['complete_for_capability_startup']).lower()}")
    print(f"- raw_artifact_reads_required={str(startup_contract['raw_artifact_reads_required']).lower()}; policy={startup_contract['raw_artifact_read_policy']}")
    missing_state = "; ".join(startup_contract["missing_state"]) or "none"
    print(f"- missing_state={missing_state}")
    print(f"- confidence_caveats={'; '.join(startup_contract['confidence_caveats'])}")
    print(f"- cli_fallback={'; '.join(startup_contract['cli_fallback'])}")
    context = _capability_context(capability_name)
    if context:
        print("- capability_context="
              f"capability={context['capability']} | "
              f"included={', '.join(context['included_state_families']) or 'none'} | "
              f"missing={', '.join(context['missing_state_families']) or 'none'} | "
              f"cli_fallback={'; '.join(context['cli_fallback']) or 'none'}")
    if closeout_context:
        closeout_contract = closeout_context["source_contract"]
        print("closeout_context:")
        print(
            "- "
            f"complete_for_closeout_context={str(closeout_contract['complete_for_closeout_context']).lower()} | "
            f"caveated={str(closeout_contract['caveated']).lower()} | "
            f"fallback={'; '.join(closeout_context['fallback_commands'])}"
        )
    if evidence_context:
        evidence_contract = evidence_context["source_contract"]
        print("evidence_context:")
        print(
            "- "
            f"complete_for_evidence_context={str(evidence_contract['complete_for_evidence_context']).lower()} | "
            f"caveated={str(evidence_contract['caveated']).lower()} | "
            f"fallback={'; '.join(evidence_context['fallback_commands'])}"
        )
    return 0


def _query_generic_entries(args: argparse.Namespace, schemas: dict, name: str) -> list[dict]:
    info = schemas[name]
    data = _load_artifact(_artifact_path(info, name))
    entries = _extract_entries(data)
    if not entries:
        return []
    topic = getattr(args, "topic", None)
    sev = getattr(args, "severity", None)
    dim = getattr(args, "dimension", None)
    status = getattr(args, "status", None)
    if topic:
        entries = _filter_by_topic(entries, topic, info["fields"])
    if sev:
        entries = _filter_by_field_value(entries, "severity", sev)
    if status:
        entries = _filter_by_field_value(entries, "status", status)
    if dim:
        entries = _filter_by_field_value(entries, "dimension", dim, substring=True)
        if not entries:
            entries = _filter_by_field_value(
                _extract_entries(data), "dimensions", dim, substring=True,
            )
    return entries


def _query_generic(args: argparse.Namespace, schemas: dict, name: str) -> int:
    output_format = getattr(args, "format", "text")
    entries = _query_generic_entries(args, schemas, name)
    if output_format != "text":
        _emit_structured(entries, output_format)
        return 0
    if not entries:
        return 0
    info = schemas[name]
    disp = _display_fields(info["fields"])
    for e in entries:
        line = _format_entry(e, disp)
        if line:
            print(line)
    return 0


STATE_COMMAND_HANDLERS = {
    "decisions": _query_decisions,
    "docs": _query_docs,
    "experiments": _query_experiments,
    "health": _query_health,
    "objective": _query_objective,
    "plan": _query_plan,
    "progress": _query_progress,
    "todo": _query_todo,
}


def cmd_state(args: argparse.Namespace) -> int:
    _validate_filter_values(args, COMMAND_FILTERS.get(args.command, []))
    if hasattr(args, "limit") and getattr(args, "limit") is not None and getattr(args, "limit") < 0:
        raise ValueError("limit must be zero or greater")
    schemas = _load_schemas(_discover_schemas_dir())
    handler = STATE_COMMAND_HANDLERS[args.command]
    return handler(args, schemas)


def cmd_query(args: argparse.Namespace) -> int:
    output_format = getattr(args, "format", "text")
    _validate_filter_values(args, COMMAND_FILTERS["query"])
    if getattr(args, "limit", None) is not None and args.limit < 0:
        raise ValueError("limit must be zero or greater")
    if getattr(args, "list_artifacts", False):
        schemas = _load_schemas(_discover_schemas_dir())
        names = sorted(schemas)
        if output_format != "text":
            _emit_structured(names, output_format)
            return 0
        for name in sorted(schemas):
            print(name)
        return 0
    query: str = args.query
    if not query:
        print("Error: query pattern required (or use --list-artifacts)", file=sys.stderr)
        return 1
    _validate_agent_string(query, "query")
    if any(marker in query for marker in ("/", "\\")) or query in {".", ".."} or ENCODED_TRAVERSAL_RE.search(query):
        raise ValueError(f"unsupported artifact/query name {query!r}; path-like values are not artifact names")
    if query in STATE_COMMAND_HANDLERS:
        print(
            f"Unsupported routine query: {query}. Use `agentera {query}` instead.",
            file=sys.stderr,
        )
        return 1
    schemas = _load_schemas(_discover_schemas_dir())
    handlers = {
        "last-phase": _query_last_phase,
        "design": _query_design,
        "open-todos": _query_open_todos,
        "session": _query_session,
    }
    if query in handlers:
        if output_format != "text" and query in schemas:
            return _query_generic(args, schemas, query)
        return handlers[query](args, schemas)
    if query in schemas:
        return _query_generic(args, schemas, query)
    for name in schemas:
        if query in (name, name.rstrip("s"), name + "s"):
            return _query_generic(args, schemas, name)
    print(f"Unknown query: {query}", file=sys.stderr)
    return 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="agentera",
        description="agentera: read project state, upgrade installs, and print priming guidance",
    )
    sub = parser.add_subparsers(dest="command")

    def add_structured_args(command_parser: argparse.ArgumentParser) -> None:
        command_parser.add_argument("--format", choices=["text", "json", "yaml"], default="text", help="Output format")
        command_parser.add_argument("--fields", help="Comma-separated structured output fields to include with command/status context")

    sub.add_parser(
        "prime",
        help="Print agent-priming guidance (routing, recovery)",
    )

    describe = sub.add_parser(
        "describe",
        help="Runtime CLI/schema introspection",
    )
    describe.add_argument("--format", choices=["json", "yaml"], default="json", help="Output format")

    hej = sub.add_parser(
        "hej",
        help="Composite orientation briefing",
    )
    hej.add_argument(
        "--install-root",
        type=_agent_path,
        default=None,
        help="Agentera app home to include in app status (default: AGENTERA_HOME, then platform data home)",
    )
    hej.add_argument(
        "--home",
        type=_agent_path,
        default=Path.home(),
        help="Home directory used for the default app home",
    )
    hej.add_argument(
        "--expected-version",
        type=_agent_version,
        default=None,
        help="Expected suite version for app status (default: AGENTERA_EXPECTED_VERSION, then registry.json in this source)",
    )
    hej.add_argument(
        "--capability-context",
        type=_agent_command,
        help="Include capability-specific startup state needs in structured source_contract output",
    )
    add_structured_args(hej)

    decisions = sub.add_parser("decisions", help="Decision log")
    decisions.add_argument("--topic", help="Filter by topic (substring match on text fields)")
    add_structured_args(decisions)

    health = sub.add_parser("health", help="Latest health audit")
    health.add_argument("--dimension", help="Filter by dimension name")
    add_structured_args(health)

    todo = sub.add_parser("todo", help="TODO summary")
    todo.add_argument("--severity", help="Filter by severity level")
    todo.add_argument("--status", help="Filter by status")
    add_structured_args(todo)

    plan = sub.add_parser("plan", help="Active plan summary")
    plan.add_argument("--status", help="Filter plan tasks by status")
    add_structured_args(plan)

    progress = sub.add_parser("progress", help="Recent cycle summary")
    progress.add_argument("--topic", help="Filter by topic (substring match on text fields)")
    progress.add_argument("--status", help="Filter progress entries by type")
    progress.add_argument("--limit", type=int, default=5, help="Limit recent entries")
    add_structured_args(progress)

    docs = sub.add_parser("docs", help="Documentation contract summary")
    docs.add_argument("--topic", help="Filter docs by topic")
    docs.add_argument("--status", help="Filter docs by status")
    add_structured_args(docs)

    objective = sub.add_parser("objective", help="Active optimera objective summary")
    objective.add_argument("--status", help="Filter legacy objective entries by status")
    add_structured_args(objective)

    experiments = sub.add_parser("experiments", help="Active optimera experiments summary")
    experiments.add_argument("--topic", help="Filter by topic (substring match on text fields)")
    experiments.add_argument("--status", help="Filter by status")
    experiments.add_argument("--limit", type=int, default=5, help="Limit recent entries")
    add_structured_args(experiments)

    compact = sub.add_parser(
        "compact",
        help="Check or fix artifact compaction budgets",
    )
    compact.add_argument(
        "--project",
        type=_agent_path,
        default=Path.cwd(),
        help="Project directory whose artifacts should be checked or compacted (default: cwd)",
    )
    compact.add_argument(
        "--mode",
        choices=["check", "fix"],
        default="check",
        help="Check only, or apply compaction to over-limit compactable artifacts",
    )
    compact.add_argument("--format", choices=["text", "json"], default="text", help="Output format")

    gate = sub.add_parser(
        "gate",
        help="Run check-only repository gates",
    )
    gate.add_argument(
        "--project",
        type=_agent_path,
        default=Path.cwd(),
        help="Project directory whose repository gates should check (default: cwd)",
    )
    gate.add_argument("--format", choices=["text", "json"], default="text", help="Output format")

    q = sub.add_parser("query", help="Advanced custom artifact query")
    q.add_argument("query", nargs="?", help="Query pattern or artifact name")
    q.add_argument("--list-artifacts", action="store_true", help="List all discovered artifact types")
    q.add_argument("--format", choices=["text", "json", "yaml"], default="text", help="Output format")
    q.add_argument("--topic", help="Filter by topic (substring match on text fields)")
    q.add_argument("--severity", help="Filter by severity level")
    q.add_argument("--dimension", help="Filter by dimension name")
    q.add_argument("--status", help="Filter by status/type where supported")
    q.add_argument("--limit", type=int, default=5, help="Limit recent entries for summary queries")

    lint = sub.add_parser(
        "lint",
        help="Run pre-write artifact prose self-audit",
    )
    lint.add_argument(
        "--artifact",
        required=True,
        help="Canonical artifact name for budget selection, e.g. PROGRESS.md",
    )
    lint_input = lint.add_mutually_exclusive_group()
    lint_input.add_argument("--file", type=_agent_path, help="Read artifact prose from a file")
    lint_input.add_argument("--text", help="Read artifact prose from this argument")
    lint.add_argument(
        "--strict",
        action="store_true",
        help="Exit non-zero when self-audit checks fail",
    )
    lint.add_argument("--format", choices=["text", "json"], default="text", help="Output format")

    u = sub.add_parser(
        "upgrade",
        help="Plan or apply an idempotent v1-to-v2 upgrade",
    )
    u.add_argument(
        "--project",
        type=_agent_path,
        default=Path.cwd(),
        help="Project directory whose .agentera artifacts should be migrated (default: cwd)",
    )
    u.add_argument(
        "--install-root",
        type=_agent_path,
        default=None,
        help="Agentera app home to wire into runtime configs (default: this app, or platform data home for packaged uvx runs)",
    )
    u.add_argument(
        "--home",
        type=_agent_path,
        default=Path.home(),
        help="Home directory for runtime config writes/detection (default: current user home)",
    )
    u.add_argument(
        "--runtime",
        action="append",
        choices=["claude", "opencode", "copilot", "codex"],
        help="Runtime to include; may be repeated (default: all runtimes)",
    )
    u.add_argument(
        "--only",
        action="append",
        choices=["bundle", "artifacts", "runtime", "cleanup", "packages"],
        help="Upgrade phase to include; may be repeated (default: all phases)",
    )
    u.add_argument(
        "--dry-run",
        action="store_true",
        help="Plan only and write nothing (default unless --yes is provided)",
    )
    u.add_argument(
        "--yes",
        action="store_true",
        help="Apply pending local upgrade actions",
    )
    u.add_argument(
        "--force",
        action="store_true",
        help="Overwrite managed runtime files or conflicting backups where explicitly supported",
    )
    u.add_argument(
        "--json",
        action="store_true",
        help="Emit structured JSON instead of human-readable text",
    )
    u.add_argument(
        "--update-packages",
        action="store_true",
        help="Also run external npx skills update commands for package-managed runtimes",
    )
    u.add_argument(
        "--copilot-rc-file",
        type=_agent_path,
        default=None,
        help="Override Copilot shell rc target (useful for previewing or tests)",
    )
    u.add_argument(
        "--opencode-config-dir",
        type=_agent_path,
        default=None,
        help="Override OPENCODE_CONFIG_DIR for plugin copy and stale-command cleanup",
    )

    b = sub.add_parser(
        "doctor",
        help="Check Agentera CLI, app, and runtime status",
    )
    b.add_argument(
        "--install-root",
        type=_agent_path,
        default=None,
        help="Agentera app home to inspect (default: AGENTERA_HOME, then platform data home)",
    )
    b.add_argument(
        "--home",
        type=_agent_path,
        default=Path.home(),
        help="Home directory used for the default app home",
    )
    b.add_argument(
        "--project",
        type=_agent_path,
        default=Path.cwd(),
        help="Project directory used when probing the installed CLI",
    )
    b.add_argument(
        "--expected-version",
        type=_agent_version,
        default=None,
        help="Expected suite version (default: registry.json in the fresh source)",
    )
    b.add_argument(
        "--expect-command",
        action="append",
        type=_agent_command,
        help="Installed CLI command that must be discoverable; may be repeated (default: hej)",
    )
    b.add_argument(
        "--json",
        action="store_true",
        help="Emit structured JSON instead of human-readable text",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.command == "prime":
            return cmd_prime(args)
        if args.command == "describe":
            return cmd_describe(args)
        if args.command == "hej":
            return cmd_hej(args)
        if args.command in STATE_COMMAND_HANDLERS:
            return cmd_state(args)
        if args.command == "query":
            return cmd_query(args)
        if args.command == "compact":
            return cmd_compact(args)
        if args.command == "gate":
            return cmd_gate(args)
        if args.command == "lint":
            return cmd_lint(args)
        if args.command == "upgrade":
            return cmd_upgrade(args)
        if args.command == "doctor":
            return cmd_doctor(args)
    except (RuntimeError, ValueError) as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 2
    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
