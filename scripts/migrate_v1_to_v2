#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""Deprecated wrapper for the artifact phase of ``agentera upgrade``."""

import os
import subprocess
import sys

print(
    "WARNING: scripts/migrate_v1_to_v2 is deprecated. "
    "Use scripts/agentera upgrade --only artifacts.",
    file=sys.stderr,
)

script_dir = (
    os.path.dirname(os.path.abspath(__file__))
    if "__file__" in globals()
    else os.getcwd()
)
target = os.path.join(script_dir, "agentera")
args = [arg for arg in sys.argv[1:] if arg != "--verbose"]
if "--dry-run" not in args and "--yes" not in args:
    args.append("--yes")

raise SystemExit(
    subprocess.run(
        [sys.executable, target, "upgrade", "--only", "artifacts", *args],
        check=False,
    ).returncode
)
