#!/usr/bin/env bash
# Optimera harness: measure hej session token consumption.
#
# This is the locked, single source of truth for the hej-token metric.
# Do NOT modify during optimization cycles; only edit under an explicit
# /optimera brainstorm refinement, with user approval.
#
# Pipeline:
#   1. Ensure the Docker vehicle image is built.
#   2. Snapshot the target repo into a staging dir (so read-only bind mounts
#      see a stable copy while experiments modify the source tree).
#   3. Create a timestamped run directory.
#   4. Run two conditions in sequence:
#        without: no --plugin-dir (baseline)
#        with:    --plugin-dir /plugins/hej mounted
#   5. Parse transcripts, apply causal+structural gates, aggregate read log.
#   6. Emit one JSON line on stdout per optimera output-schema.md.
#
# Environment overrides:
#   TARGET_REPO       absolute path to the agentera repo under test
#                     (default: the repo containing this harness)
#   HEJ_PLUGIN_DIR    absolute path to the hej skill directory to mount
#                     (default: $TARGET_REPO/skills/hej)
#   MODEL             model id for claude -p (default: claude-sonnet-4-6)
#   TRIGGER_PROMPT    prompt that activates hej
#                     (default: the one from scripts/eval_skills.py)
#   RUN_ID            identifier for the run dir; defaults to a timestamp
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HARNESS_ROOT="$SCRIPT_DIR"
REPO_DEFAULT="$(cd "$SCRIPT_DIR/.." && pwd)"

TARGET_REPO="${TARGET_REPO:-$REPO_DEFAULT}"
HEJ_PLUGIN_DIR="${HEJ_PLUGIN_DIR:-$TARGET_REPO/skills/hej}"
MODEL="${MODEL:-claude-sonnet-4-6}"
TRIGGER_PROMPT="${TRIGGER_PROMPT:-Start a new session and give me a status briefing on this project.}"
RUN_ID="${RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)}"
RUN_DIR="$HARNESS_ROOT/runs/$RUN_ID"

CLAUDE_BIN="${CLAUDE_BIN:-/opt/claude-code/bin/claude}"
IMAGE_TAG="${IMAGE_TAG:-agentera-optimera-vehicle:1}"
IMAGE_BUILD_MARK="$HARNESS_ROOT/vehicle/.image-built"

DOCKER_TIMEOUT_SECONDS="${DOCKER_TIMEOUT_SECONDS:-600}"
MAX_BUDGET_USD="${MAX_BUDGET_USD:-0.75}"

HOST_CLAUDE_DIR="${HOST_CLAUDE_DIR:-$HOME/.claude}"
HOST_CREDS="$HOST_CLAUDE_DIR/.credentials.json"
HOST_CFG="$HOST_CLAUDE_DIR/.claude.json"
HOST_PROFILE_DIR="$HOST_CLAUDE_DIR/profile"

log() {
    printf '[harness] %s\n' "$*" >&2
}

die() {
    printf '[harness] ERROR: %s\n' "$*" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Prechecks
# ---------------------------------------------------------------------------

command -v docker >/dev/null 2>&1 || die "docker not found in PATH"
command -v python3 >/dev/null 2>&1 || die "python3 not found in PATH"

[ -d "$TARGET_REPO" ] || die "TARGET_REPO does not exist: $TARGET_REPO"
[ -d "$HEJ_PLUGIN_DIR" ] || die "HEJ_PLUGIN_DIR does not exist: $HEJ_PLUGIN_DIR"
[ -f "$HEJ_PLUGIN_DIR/SKILL.md" ] || die "HEJ_PLUGIN_DIR missing SKILL.md"
[ -f "$CLAUDE_BIN" ] || die "claude binary not found at $CLAUDE_BIN"
[ -f "$HOST_CREDS" ] || die "OAuth credentials missing at $HOST_CREDS"

# ---------------------------------------------------------------------------
# Build the vehicle image (idempotent; docker's layer cache handles reuse)
# ---------------------------------------------------------------------------

build_image() {
    local ctx
    ctx="$(mktemp -d)"
    # shellcheck disable=SC2064
    trap "rm -rf '$ctx'" RETURN

    cp "$HARNESS_ROOT/vehicle/Dockerfile"    "$ctx/Dockerfile"
    cp "$HARNESS_ROOT/vehicle/entrypoint.sh" "$ctx/entrypoint.sh"
    cp "$HARNESS_ROOT/vehicle/settings.json" "$ctx/settings.json"
    cp "$HARNESS_ROOT/vehicle/log_reads.py"  "$ctx/log_reads.py"
    cp "$CLAUDE_BIN"                          "$ctx/claude"

    log "building $IMAGE_TAG (context: $ctx)"
    docker build \
        --quiet \
        --tag "$IMAGE_TAG" \
        "$ctx" >&2
}

if ! docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
    build_image
    touch "$IMAGE_BUILD_MARK"
else
    log "reusing $IMAGE_TAG (already built)"
fi

# ---------------------------------------------------------------------------
# Per-run directory
# ---------------------------------------------------------------------------

mkdir -p "$RUN_DIR"
log "run dir: $RUN_DIR"

# Build a hej-only marketplace snapshot. A bare plugin directory does not
# register its SKILL.md with claude's skill loader; the loader needs a
# marketplace manifest (.claude-plugin/marketplace.json) listing the
# plugins by source path. We assemble a minimal hej-only marketplace in
# the run dir and point the container's --plugin-dir at that instead of
# the raw hej directory.
MARKETPLACE_SNAPSHOT="$RUN_DIR/marketplace-snapshot"
mkdir -p "$MARKETPLACE_SNAPSHOT/.claude-plugin"
mkdir -p "$MARKETPLACE_SNAPSHOT/skills"
cp -a "$HEJ_PLUGIN_DIR/." "$MARKETPLACE_SNAPSHOT/skills/hej/"

cat > "$MARKETPLACE_SNAPSHOT/.claude-plugin/marketplace.json" <<EOF
{
  "\$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "agentera-optimera-hej",
  "version": "1.0.0",
  "description": "Hej-only marketplace for optimera token-consumption benchmark",
  "owner": {"name": "optimera-harness"},
  "plugins": [
    {
      "name": "hej",
      "description": "HEJ: Holistic Entry Junction. Orient, Route, Activate.",
      "version": "1.10.0",
      "author": {"name": "jgabor"},
      "source": "./skills/hej",
      "category": "development"
    }
  ]
}
EOF

# Legacy alias retained so the gate and meta code below still resolves.
HEJ_SNAPSHOT="$MARKETPLACE_SNAPSHOT/skills/hej"

# ---------------------------------------------------------------------------
# Target measurements
# ---------------------------------------------------------------------------

agentera_bytes=0
if [ -d "$TARGET_REPO/.agentera" ]; then
    agentera_bytes=$(find "$TARGET_REPO/.agentera" -type f -printf '%s\n' 2>/dev/null \
                     | awk 'BEGIN{s=0} {s+=$1} END{print s}')
fi
hej_bytes=$(find "$HEJ_SNAPSHOT" -type f -printf '%s\n' 2>/dev/null \
            | awk 'BEGIN{s=0} {s+=$1} END{print s}')
target_total_bytes=$(find "$TARGET_REPO" -type f -not -path '*/.git/*' -printf '%s\n' 2>/dev/null \
                     | awk 'BEGIN{s=0} {s+=$1} END{print s}')

cat > "$RUN_DIR/target.meta" <<EOF
target_repo=$TARGET_REPO
hej_plugin_dir=$HEJ_PLUGIN_DIR
hej_snapshot=$HEJ_SNAPSHOT
model=$MODEL
trigger_prompt=$TRIGGER_PROMPT
measured_at=$(date -Iseconds)
run_id=$RUN_ID
image_tag=$IMAGE_TAG
agentera_bytes=$agentera_bytes
agentera_token_est=$(( agentera_bytes / 4 ))
hej_bytes=$hej_bytes
hej_token_est=$(( hej_bytes / 4 ))
target_total_bytes=$target_total_bytes
EOF

# ---------------------------------------------------------------------------
# Condition runner
# ---------------------------------------------------------------------------

run_condition() {
    local name="$1"
    shift
    local -a extra_flags=("$@")

    local transcript="$RUN_DIR/${name}.jsonl"
    local stderr_file="$RUN_DIR/${name}.stderr"
    local reads_file="$RUN_DIR/${name}-reads.jsonl"
    local meta_file="$RUN_DIR/${name}.meta"

    log "running condition: $name"
    local started_at=$(date -Iseconds)

    local -a profile_mount=()
    if [ -f "$HOST_PROFILE_DIR/PROFILE.md" ]; then
        profile_mount=(-v "$HOST_PROFILE_DIR:/profile:ro")
    fi

    # Hermeticity flags:
    #   --tools restricts the tool surface to a minimal explicit set; this
    #     strips default host MCP tools, CronCreate/TaskCreate/etc. from the
    #     system prompt.
    #   --strict-mcp-config + --mcp-config with an empty JSON disables all
    #     MCP server connections (host cloud MCPs like claude.ai Linear and
    #     Cloudflare would otherwise auto-connect via the OAuth session).
    #   --agents '{}' overrides the default agents set so host agents do not
    #     leak into the container.
    #   --setting-sources "" prevents loading user/project/local settings
    #     files (the mounted /creds/.claude.json still supplies OAuth).
    local exit_code=0
    timeout "${DOCKER_TIMEOUT_SECONDS}s" docker run \
        --rm \
        --network host \
        -v "$TARGET_REPO:/workspace:ro" \
        -v "$MARKETPLACE_SNAPSHOT:/plugins/agentera-hej:ro" \
        -v "$HOST_CREDS:/creds/.credentials.json:ro" \
        -v "$HOST_CFG:/creds/.claude.json:ro" \
        "${profile_mount[@]}" \
        -v "$RUN_DIR:/output:rw" \
        -e "BENCH_READS_LOG=/output/${name}-reads.jsonl" \
        "$IMAGE_TAG" \
        claude -p "$TRIGGER_PROMPT" \
            --model "$MODEL" \
            --output-format stream-json \
            --verbose \
            --no-session-persistence \
            --dangerously-skip-permissions \
            --max-budget-usd "$MAX_BUDGET_USD" \
            --add-dir /workspace \
            --tools Read Glob Grep Bash Skill \
            --strict-mcp-config \
            --mcp-config '{"mcpServers":{}}' \
            --agents '{}' \
            --setting-sources '' \
            --settings /opt/bench/settings.json \
            "${extra_flags[@]}" \
        > "$transcript" 2> "$stderr_file" || exit_code=$?

    local finished_at=$(date -Iseconds)

    cat > "$meta_file" <<EOF
condition=$name
started_at=$started_at
finished_at=$finished_at
exit_code=$exit_code
transcript=$transcript
reads_log=$reads_file
EOF

    if [ $exit_code -ne 0 ]; then
        log "condition '$name' exited $exit_code; see $stderr_file"
    fi

    return $exit_code
}

# ---------------------------------------------------------------------------
# Run both conditions
# ---------------------------------------------------------------------------

without_ok=1
with_ok=1

run_condition without || without_ok=0
run_condition with --plugin-dir /plugins/agentera-hej || with_ok=0

# ---------------------------------------------------------------------------
# Parse + gate + aggregate
# ---------------------------------------------------------------------------

python3 "$HARNESS_ROOT/parse_tokens.py" "$RUN_DIR/without.jsonl" > "$RUN_DIR/without.tokens.json" || true
python3 "$HARNESS_ROOT/parse_tokens.py" "$RUN_DIR/with.jsonl"    > "$RUN_DIR/with.tokens.json"    || true

python3 "$HARNESS_ROOT/check_gates.py"  "$RUN_DIR/with.jsonl"    > "$RUN_DIR/with.gates.json"    || true
python3 "$HARNESS_ROOT/check_gates.py"  "$RUN_DIR/without.jsonl" > "$RUN_DIR/without.gates.json" || true

python3 "$HARNESS_ROOT/aggregate_reads.py" "$RUN_DIR/with-reads.jsonl"    10 > "$RUN_DIR/with.reads.json"    || true
python3 "$HARNESS_ROOT/aggregate_reads.py" "$RUN_DIR/without-reads.jsonl" 10 > "$RUN_DIR/without.reads.json" || true

# ---------------------------------------------------------------------------
# Compose final JSON output
# ---------------------------------------------------------------------------

python3 - "$RUN_DIR" "$without_ok" "$with_ok" <<'PY'
import json
import os
import sys

run_dir = sys.argv[1]
without_ok = sys.argv[2] == "1"
with_ok = sys.argv[3] == "1"

def load(name):
    path = os.path.join(run_dir, name)
    if not os.path.exists(path) or os.path.getsize(path) == 0:
        return None
    with open(path) as fh:
        try:
            return json.load(fh)
        except json.JSONDecodeError:
            return None

w_tokens = load("with.tokens.json") or {}
wo_tokens = load("without.tokens.json") or {}
w_gates = load("with.gates.json") or {}
w_reads = load("with.reads.json") or {}
wo_reads = load("without.reads.json") or {}

def composite(tokens):
    # primary metric: peak_context + output_total (stable across runs,
    # captures widest-point work plus generation). See OBJECTIVE.md for
    # rationale.
    return (tokens.get("peak_context", 0) or 0) + (tokens.get("output_tokens", 0) or 0)

primary = composite(w_tokens)
baseline = composite(wo_tokens)
delta = primary - baseline
raw_total_with = w_tokens.get("total", 0)
raw_total_without = wo_tokens.get("total", 0)

# Gate enforcement: if either run failed to execute, or gates failed,
# emit a non-zero exit so the cycle logs it as an error.
gates_pass = bool(w_gates.get("both_pass", False))
runs_ok = with_ok and without_ok

status = "ok"
if not runs_ok:
    status = "run_error"
elif not gates_pass:
    status = "gate_fail"

def top_reads(reads_obj):
    out = []
    for entry in reads_obj.get("top_contributors", [])[:5]:
        out.append({
            "name": f"read:{entry['path']}",
            "value": entry["bytes"],
            "unit": "bytes",
        })
    return out

breakdown = [
    {"name": "delta_vs_baseline",       "value": delta,                      "unit": "tokens"},
    {"name": "baseline_composite",      "value": baseline,                   "unit": "tokens"},
    {"name": "raw_total_with",          "value": raw_total_with,             "unit": "tokens"},
    {"name": "raw_total_without",       "value": raw_total_without,          "unit": "tokens"},
    {"name": "peak_context",            "value": w_tokens.get("peak_context", 0), "unit": "tokens"},
    {"name": "output_total",            "value": w_tokens.get("output_tokens", 0), "unit": "tokens"},
    {"name": "cache_read_total",        "value": w_tokens.get("cache_read_tokens", 0), "unit": "tokens"},
    {"name": "cache_create_total",      "value": w_tokens.get("cache_create_tokens", 0), "unit": "tokens"},
    {"name": "input_total",             "value": w_tokens.get("input_tokens", 0), "unit": "tokens"},
    {"name": "cache_efficiency",        "value": w_tokens.get("cache_efficiency", 0.0), "unit": "ratio"},
    {"name": "turns",                   "value": w_tokens.get("turns", 0), "unit": "count"},
    {"name": "tool_uses",               "value": w_tokens.get("tool_use_count", 0), "unit": "count"},
    {"name": "read_total_effective",    "value": w_reads.get("total_effective_bytes", 0), "unit": "bytes"},
    {"name": "read_count",              "value": w_reads.get("total_reads", 0), "unit": "count"},
]

for cls, stats in sorted((w_reads.get("by_class") or {}).items()):
    breakdown.append({
        "name": f"read_class:{cls}",
        "value": stats.get("bytes", 0),
        "unit": "bytes",
    })

breakdown.extend(top_reads(w_reads))

gate_detail = (
    "gates_pass" if gates_pass
    else f"gates_fail: {json.dumps(w_gates.get('signals', {}))}"
)

output = {
    "metric": primary,
    "direction": "lower",
    "unit": "tokens",
    "detail": (
        f"hej session peak_context+output (composite), "
        f"model={os.environ.get('MODEL', 'claude-sonnet-4-6')}, "
        f"status={status}, {gate_detail}"
    ),
    "breakdown": breakdown,
}
print(json.dumps(output))
# Non-zero exit signals the harness-level failure even though JSON is written.
if not runs_ok or not gates_pass:
    sys.exit(3)
PY
