{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "uv run ${AGENTERA_HOME}/app/scripts/cursor_session_start.py", "timeout": 15 }
    ],
    "preToolUse": [
      {
        "command": "uv run ${AGENTERA_HOME}/hooks/cursor_pre_tool_use.py",
        "timeout": 15,
        "matcher": "Write|Edit"
      }
    ],
    "sessionEnd": [
      { "command": "uv run ${AGENTERA_HOME}/hooks/cursor_session_stop.py", "timeout": 15 }
    ]
  }
}
