{
  "description": "agentera v2 Codex hooks: schema-backed apply_patch artifact validation, parity with Claude Code PostToolUse and OpenCode tool.execute.after",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y agentera hook validate-artifact",
            "timeout": 10,
            "statusMessage": "validating artifact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y agentera hook validate-artifact",
            "timeout": 10,
            "statusMessage": "validating artifact"
          }
        ]
      }
    ]
  }
}
