{
  "description": "agentera Codex hooks: real-time apply_patch artifact validation, parity with Claude Code PostToolUse and OpenCode tool.execute.after",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AGENTERA_HOME}/hooks/validate_artifact.py\"",
            "timeout": 10,
            "statusMessage": "validating artifact"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${AGENTERA_HOME}/hooks/validate_artifact.py\"",
            "timeout": 10,
            "statusMessage": "validating artifact"
          }
        ]
      }
    ]
  }
}
