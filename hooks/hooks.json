{
  "description": "agentera v2 hooks: session context preloading, session persistence, and schema-backed artifact validation against skills/agentera/schemas/artifacts/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y agentera@next hook session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y agentera@next hook session-stop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y agentera@next hook validate-artifact"
          }
        ]
      }
    ]
  }
}
